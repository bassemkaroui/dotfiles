#!/usr/bin/env bash
#MISE description="Install zsh, oh-my-zsh, plugins, p10k, and fonts (no .zshrc modifications)"
#MISE raw=true
#MISE depends_post=["setup:p10k-configure"]
set -eo pipefail

# ─── Helpers ───────────────────────────────────────────────────────────────────

info()  { printf '\033[1;34m[INFO]\033[0m   %s\n' "$*"; }
warn()  { printf '\033[1;33m[WARN]\033[0m   %s\n' "$*"; }
ok()    { printf '\033[1;32m[ OK ]\033[0m   %s\n' "$*"; }
ok_changed() { printf '\033[1;32m[ OK ] \033[1;32m●\033[0m %s\n' "$*"; }
fail()  { printf '\033[1;31m[FAIL]\033[0m   %s\n' "$*"; exit 1; }

ZSH_CUSTOM="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}"

# ─── Phase 1: Install zsh ─────────────────────────────────────────────────────

info "Phase 1: Install zsh"
if command -v zsh &>/dev/null; then
    ok "zsh already installed: $(command -v zsh)"
else
    info "zsh not found, attempting install..."
    if command -v sudo &>/dev/null && sudo -n true 2>/dev/null || true; then
        if command -v apt &>/dev/null; then
            info "Installing zsh via apt..."
            sudo apt update -qq && sudo apt install -y zsh
        elif command -v dnf &>/dev/null; then
            info "Installing zsh via dnf..."
            sudo dnf install -y zsh
        elif command -v pacman &>/dev/null; then
            info "Installing zsh via pacman..."
            sudo pacman -S --noconfirm zsh
        else
            info "No supported package manager with sudo, trying source build..."
        fi
    fi

    if ! command -v zsh &>/dev/null; then
        info "Falling back to compiling zsh from source into ~/.local/"
        for tool in gcc make autoconf; do
            command -v "$tool" &>/dev/null || fail "Cannot compile zsh: '$tool' not found. Install build tools first."
        done
        ZSH_VERSION_SRC="5.9"
        ZSH_TARBALL="zsh-${ZSH_VERSION_SRC}.tar.xz"
        ZSH_URL="https://sourceforge.net/projects/zsh/files/zsh/${ZSH_VERSION_SRC}/${ZSH_TARBALL}/download"
        TMPDIR_ZSH="$(mktemp -d)"
        trap 'rm -rf "$TMPDIR_ZSH"' EXIT
        info "Downloading zsh $ZSH_VERSION_SRC source..."
        curl -fSL -o "$TMPDIR_ZSH/$ZSH_TARBALL" "$ZSH_URL"
        cd "$TMPDIR_ZSH"
        if command -v xz &>/dev/null; then
            tar xf "$ZSH_TARBALL"
        elif command -v python3 &>/dev/null; then
            info "xz not found, decompressing with python3..."
            python3 -c "import lzma, tarfile, sys; tarfile.open(fileobj=lzma.open(sys.argv[1])).extractall()" "$ZSH_TARBALL"
        else
            fail "Cannot decompress .tar.xz: neither xz nor python3 available"
        fi
        cd "zsh-${ZSH_VERSION_SRC}"
        ./configure --prefix="$HOME/.local" --quiet
        make -j"$(nproc)" --quiet
        make install --quiet
        cd "$HOME"
        if [[ ":$PATH:" != *":$HOME/.local/bin:"* ]]; then
            export PATH="$HOME/.local/bin:$PATH"
        fi
        command -v zsh &>/dev/null || fail "zsh compilation succeeded but binary not found in PATH"
        ok_changed "zsh compiled and installed to ~/.local/bin/zsh"
    else
        ok_changed "zsh installed successfully"
    fi
fi

# ─── Phase 2: Set zsh as default shell ────────────────────────────────────────

info "Phase 2: Set zsh as default shell"
CURRENT_SHELL="$(getent passwd "${USER:-$(whoami)}" 2>/dev/null | cut -d: -f7 || true)"
[[ -z "$CURRENT_SHELL" ]] && CURRENT_SHELL="${SHELL:-}"
ZSH_PATH="$(command -v zsh)"

if [[ "$CURRENT_SHELL" == *zsh* ]]; then
    ok "Default shell is already zsh: $CURRENT_SHELL"
else
    info "Current shell: $CURRENT_SHELL — changing to zsh..."
    # Ensure zsh is in /etc/shells
    if [[ -f /etc/shells ]] && ! grep -qx "$ZSH_PATH" /etc/shells 2>/dev/null; then
        if [[ -w /etc/shells ]]; then
            echo "$ZSH_PATH" >> /etc/shells
            ok_changed "Added $ZSH_PATH to /etc/shells"
        elif command -v sudo &>/dev/null; then
            info "Adding $ZSH_PATH to /etc/shells..."
            echo "$ZSH_PATH" | sudo tee -a /etc/shells >/dev/null || warn "Could not add zsh to /etc/shells"
        else
            warn "Cannot add zsh to /etc/shells (no write permission and no sudo)"
        fi
    fi
    SHELL_CHANGED=false

    # Method 1: sudo chsh (root bypasses PAM password prompt for target user)
    if [[ "$SHELL_CHANGED" == false ]] && command -v sudo &>/dev/null && command -v chsh &>/dev/null; then
        info "Trying: sudo chsh -s $ZSH_PATH $USER"
        if sudo chsh -s "$ZSH_PATH" "$USER"; then
            ok_changed "Default shell changed to $ZSH_PATH via sudo chsh"
            SHELL_CHANGED=true
        fi
    fi

    # Method 2: chsh directly (let PAM prompt user for their password)
    if [[ "$SHELL_CHANGED" == false ]] && command -v chsh &>/dev/null; then
        info "Trying: chsh -s $ZSH_PATH"
        if chsh -s "$ZSH_PATH"; then
            ok_changed "Default shell changed to $ZSH_PATH via chsh"
            SHELL_CHANGED=true
        fi
    fi

    # Method 3: sudo usermod (allow sudo password prompt)
    if [[ "$SHELL_CHANGED" == false ]] && command -v sudo &>/dev/null; then
        info "Trying: sudo usermod -s $ZSH_PATH $USER"
        if sudo usermod -s "$ZSH_PATH" "$USER"; then
            ok_changed "Default shell changed to $ZSH_PATH via sudo usermod"
            SHELL_CHANGED=true
        fi
    fi

    # Method 4: Login file fallback (exec zsh)
    if [[ "$SHELL_CHANGED" == false ]]; then
        warn "Could not change shell via chsh or usermod"
        warn "Falling back to 'exec zsh' in login file (only works for TTY/SSH logins,"
        warn "graphical terminal emulators read the shell from /etc/passwd)"

        # Always use ~/.bash_profile — it takes priority over ~/.profile (which
        # is managed by stow and would overwrite our changes) and ~/.bash_login.
        LOGIN_FILE="$HOME/.bash_profile"

        if ! grep -q 'exec zsh' "$LOGIN_FILE" 2>/dev/null; then
            echo "export SHELL=$ZSH_PATH" >> "$LOGIN_FILE"
            echo 'exec zsh' >> "$LOGIN_FILE"
            ok_changed "Added exec zsh to $LOGIN_FILE"
        else
            ok "exec zsh already in $LOGIN_FILE"
        fi
    fi
fi

# ─── Phase 3: Install oh-my-zsh ──────────────────────────────────────────────

info "Phase 3: Install oh-my-zsh"
if [[ -d "$HOME/.oh-my-zsh" ]]; then
    ok "oh-my-zsh already installed"
else
    info "Installing oh-my-zsh..."
    # Save original .zshrc if it exists (could be our dotfiles symlink)
    ZSHRC_BACKUP=""
    if [[ -e "$HOME/.zshrc" ]]; then
        ZSHRC_BACKUP="$(mktemp)"
        cp -a "$HOME/.zshrc" "$ZSHRC_BACKUP"
    fi

    RUNZSH=no CHSH=no KEEP_ZSHRC=no sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"

    # Restore original .zshrc (oh-my-zsh overwrites it)
    if [[ -n "$ZSHRC_BACKUP" ]]; then
        if [[ -f "$HOME/.zshrc.pre-oh-my-zsh" ]]; then
            info "Restoring original .zshrc from oh-my-zsh backup..."
            mv -f "$HOME/.zshrc.pre-oh-my-zsh" "$HOME/.zshrc"
        elif [[ -f "$ZSHRC_BACKUP" ]]; then
            info "Restoring original .zshrc from our backup..."
            mv -f "$ZSHRC_BACKUP" "$HOME/.zshrc"
        fi
        rm -f "$ZSHRC_BACKUP" 2>/dev/null
    fi

    ok_changed "oh-my-zsh installed"
fi

# ─── Phase 4: Install zsh plugins ────────────────────────────────────────────

info "Phase 4: Install zsh plugins"
PLUGINS=(
    "zsh-autosuggestions|https://github.com/zsh-users/zsh-autosuggestions.git"
    "zsh-syntax-highlighting|https://github.com/zsh-users/zsh-syntax-highlighting.git"
)

for entry in "${PLUGINS[@]}"; do
    PLUGIN_NAME="${entry%%|*}"
    PLUGIN_URL="${entry##*|}"
    PLUGIN_DIR="$ZSH_CUSTOM/plugins/$PLUGIN_NAME"
    if [[ -d "$PLUGIN_DIR" ]]; then
        ok "Plugin $PLUGIN_NAME already installed"
    else
        info "Cloning $PLUGIN_NAME..."
        git clone --depth=1 "$PLUGIN_URL" "$PLUGIN_DIR"
        ok_changed "Installed $PLUGIN_NAME"
    fi
done

# ─── Phase 5: Install powerlevel10k + font ───────────────────────────────────

info "Phase 5: Install powerlevel10k + font"
P10K_DIR="$ZSH_CUSTOM/themes/powerlevel10k"
if [[ -d "$P10K_DIR" ]]; then
    ok "powerlevel10k already installed"
else
    info "Cloning powerlevel10k..."
    git clone --depth=1 https://github.com/romkatv/powerlevel10k.git "$P10K_DIR"
    ok_changed "Installed powerlevel10k"
fi

# Install FiraCode Nerd Font
FONT_DIR="$HOME/.local/share/fonts"
FONT_FILE="$FONT_DIR/FiraCodeNerdFont-Medium.ttf"
if [[ -f "$FONT_FILE" ]]; then
    ok "FiraCode Nerd Font already installed"
else
    info "Installing FiraCode Nerd Font..."
    mkdir -p "$FONT_DIR"
    TMPDIR_FONT="$(mktemp -d)"
    curl -fSL -o "$TMPDIR_FONT/FiraCode.zip" \
        "https://github.com/ryanoasis/nerd-fonts/releases/latest/download/FiraCode.zip"
    if command -v unzip &>/dev/null; then
        unzip -o "$TMPDIR_FONT/FiraCode.zip" "FiraCodeNerdFont-Medium.ttf" -d "$FONT_DIR" \
            || unzip -o "$TMPDIR_FONT/FiraCode.zip" -d "$FONT_DIR"
    elif command -v python3 &>/dev/null; then
        python3 -c "
import zipfile, sys
with zipfile.ZipFile('$TMPDIR_FONT/FiraCode.zip') as z:
    targets = [n for n in z.namelist() if 'FiraCodeNerdFont-Medium.ttf' in n]
    if not targets:
        targets = z.namelist()
    for t in targets:
        z.extract(t, '$FONT_DIR')
"
    elif command -v busybox &>/dev/null && busybox unzip -l "$TMPDIR_FONT/FiraCode.zip" &>/dev/null; then
        busybox unzip -o "$TMPDIR_FONT/FiraCode.zip" -d "$FONT_DIR"
    else
        fail "Cannot extract zip: no unzip, python3, or busybox available"
    fi
    rm -rf "$TMPDIR_FONT"
    if command -v fc-cache &>/dev/null; then
        fc-cache -f -v "$FONT_DIR" >/dev/null 2>&1
    fi
    ok_changed "FiraCode Nerd Font installed"
fi

# Set terminal font to FiraCode Nerd Font
NERD_FONT="FiraCode Nerd Font Medium"
NERD_FONT_SIZE=12
FONT_SET=false

# GNOME Terminal / Tilix (dconf-based)
if command -v gnome-terminal &>/dev/null && command -v dconf &>/dev/null; then
    DCONF_WORKS=true
    if [[ -z "${DBUS_SESSION_BUS_ADDRESS:-}" ]]; then
        warn "DBUS_SESSION_BUS_ADDRESS not set — dconf cannot access GNOME Terminal settings"
        warn "(this is expected when running via su/SSH; font will need to be set from a desktop session)"
        DCONF_WORKS=false
    fi

    if [[ "$DCONF_WORKS" == true ]]; then
        PROFILES=$(dconf list /org/gnome/terminal/legacy/profiles:/ 2>/dev/null | grep '^:' | tr -d '/:' || true)

        # If no profiles found, use the well-known default profile UUID
        if [[ -z "$PROFILES" ]]; then
            PROFILES="b1dcc9dd-5262-4d8d-a863-c897e6d979b9"
            info "No GNOME Terminal profiles found in dconf, using default profile UUID"
        fi

        for PROFILE in $PROFILES; do
            CURRENT=$(dconf read "/org/gnome/terminal/legacy/profiles:/:${PROFILE}/font" 2>/dev/null | tr -d "'")
            if [[ "$CURRENT" != "${NERD_FONT} ${NERD_FONT_SIZE}" ]]; then
                dconf write "/org/gnome/terminal/legacy/profiles:/:${PROFILE}/font" "'${NERD_FONT} ${NERD_FONT_SIZE}'"
                dconf write "/org/gnome/terminal/legacy/profiles:/:${PROFILE}/use-system-font" "false"
                ok_changed "Set font for GNOME Terminal profile ${PROFILE}"
            else
                ok "GNOME Terminal profile ${PROFILE} already using ${NERD_FONT}"
            fi
        done
        FONT_SET=true
    fi
fi

# Alacritty
ALACRITTY_CFG="$HOME/.config/alacritty/alacritty.toml"
if command -v alacritty &>/dev/null; then
    mkdir -p "$(dirname "$ALACRITTY_CFG")"
    if [[ -f "$ALACRITTY_CFG" ]] && grep -q 'family' "$ALACRITTY_CFG" 2>/dev/null; then
        CURRENT=$(grep 'family' "$ALACRITTY_CFG" | head -1 | sed 's/.*"\(.*\)".*/\1/')
        if [[ "$CURRENT" == "$NERD_FONT" ]]; then
            ok "Alacritty already using ${NERD_FONT}"
        else
            sed -i "s/family = .*/family = \"${NERD_FONT}\"/" "$ALACRITTY_CFG"
            ok_changed "Set font in Alacritty config"
        fi
    else
        printf '\n[font.normal]\nfamily = "%s"\nsize = %s\n' "$NERD_FONT" "$NERD_FONT_SIZE" >> "$ALACRITTY_CFG"
        ok_changed "Set font in Alacritty config"
    fi
    FONT_SET=true
fi

# Kitty
KITTY_CFG="$HOME/.config/kitty/kitty.conf"
if command -v kitty &>/dev/null; then
    mkdir -p "$(dirname "$KITTY_CFG")"
    if [[ -f "$KITTY_CFG" ]] && grep -q '^font_family' "$KITTY_CFG" 2>/dev/null; then
        CURRENT=$(grep '^font_family' "$KITTY_CFG" | head -1 | sed 's/^font_family //')
        if [[ "$CURRENT" == "$NERD_FONT" ]]; then
            ok "Kitty already using ${NERD_FONT}"
        else
            sed -i "s/^font_family .*/font_family ${NERD_FONT}/" "$KITTY_CFG"
            ok_changed "Set font in Kitty config"
        fi
    else
        printf '\nfont_family %s\nfont_size %s\n' "$NERD_FONT" "$NERD_FONT_SIZE" >> "$KITTY_CFG"
        ok_changed "Set font in Kitty config"
    fi
    FONT_SET=true
fi

# Ghostty
GHOSTTY_CFG="$HOME/.config/ghostty/config"
if command -v ghostty &>/dev/null; then
    mkdir -p "$(dirname "$GHOSTTY_CFG")"
    if [[ -f "$GHOSTTY_CFG" ]] && grep -q '^font-family' "$GHOSTTY_CFG" 2>/dev/null; then
        CURRENT=$(grep '^font-family' "$GHOSTTY_CFG" | head -1 | sed 's/^font-family *= *//')
        if [[ "$CURRENT" == "$NERD_FONT" ]]; then
            ok "Ghostty already using ${NERD_FONT}"
        else
            sed -i "s/^font-family.*/font-family = ${NERD_FONT}/" "$GHOSTTY_CFG"
            ok_changed "Set font in Ghostty config"
        fi
    else
        printf '\nfont-family = %s\nfont-size = %s\n' "$NERD_FONT" "$NERD_FONT_SIZE" >> "$GHOSTTY_CFG"
        ok_changed "Set font in Ghostty config"
    fi
    FONT_SET=true
fi

if [[ "$FONT_SET" == false ]]; then
    warn "No supported terminal found — manually set font to '${NERD_FONT}'"
fi

# ─── Phase 6: Hostname prompt (interactive) ──────────────────────────────────

info "Phase 6: Hostname"
printf 'Would you like to change the hostname? (y/N): '
read -r CHANGE_HOSTNAME
if [[ "$CHANGE_HOSTNAME" =~ ^[Yy]$ ]]; then
    printf 'Enter new hostname: '
    read -r NEW_HOSTNAME
    if [[ -n "$NEW_HOSTNAME" ]]; then
        if command -v hostnamectl &>/dev/null; then
            sudo hostnamectl set-hostname "$NEW_HOSTNAME" 2>/dev/null && ok_changed "Hostname set to $NEW_HOSTNAME" \
                || warn "Could not set hostname (sudo required)"
        else
            warn "hostnamectl not available"
        fi
    fi
else
    ok "Hostname unchanged"
fi

# ─── Done ─────────────────────────────────────────────────────────────────────

printf '\n'
info "============================================"
info "  zsh setup complete!"
info "============================================"
info "Next steps:"
info "  1. Open a new terminal (or run: exec zsh)"
printf '\n'
