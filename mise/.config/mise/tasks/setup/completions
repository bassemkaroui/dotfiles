#!/usr/bin/env bash
#MISE description="Generate zsh completions for installed tools"
set -eo pipefail

# ─── Helpers ───────────────────────────────────────────────────────────────────

info()  { printf '\033[1;34m[INFO]\033[0m   %s\n' "$*"; }
ok()    { printf '\033[1;32m[ OK ]\033[0m   %s\n' "$*"; }
ok_changed() { printf '\033[1;32m[ OK ] \033[1;32m●\033[0m %s\n' "$*"; }
warn()  { printf '\033[1;33m[WARN]\033[0m   %s\n' "$*"; }

COMPLETIONS_DIR="$HOME/.config/completions"
mkdir -p "$COMPLETIONS_DIR"

# Each entry: "tool_name|completion_command"
TOOLS=(
    "mise|mise completions zsh"
    "gh|gh completion -s zsh"
)

info "Generating zsh completions"

for entry in "${TOOLS[@]}"; do
    tool="${entry%%|*}"
    cmd="${entry##*|}"
    target="$COMPLETIONS_DIR/_${tool}"

    if ! command -v "$tool" &>/dev/null; then
        warn "$tool not found, skipping"
        continue
    fi

    if [[ -s "$target" ]]; then
        ok "_${tool} already exists"
        continue
    fi

    if eval "$cmd" > "$target" 2>/dev/null; then
        ok_changed "Generated _${tool}"
    else
        warn "Failed to generate _${tool}"
    fi
done
