#!/usr/bin/env bash
#MISE description="Deploy dotfiles via GNU Stow (clones repo if missing, auto-detects device type)"
#MISE raw=true
set -eo pipefail

# ─── Helpers ───────────────────────────────────────────────────────────────────

TASK_NAME="setup:dotfiles"
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../lib/helpers.sh"

# Find next available .bak suffix: .bak, .bak.1, .bak.2, ...
next_backup_path() {
    local path="$1"
    local backup="$path.bak"
    local i=1
    while [[ -e "$backup" ]]; do
        backup="$path.bak.$i"
        ((i++))
    done
    printf '%s' "$backup"
}

# Directories that should always be recursed into (never backed up wholesale).
# These contain unmanaged files (GPG keys, generated completions, auth tokens)
# that must be left in place.
RECURSE_DIRS=(.gnupg .config/gh .claude .claude/plugins)

is_recurse_dir() {
    local path="$1"
    for d in "${RECURSE_DIRS[@]}"; do
        [[ "$path" == "$d" ]] && return 0
    done
    return 1
}

declare -gA SHARED_DIRS

compute_shared_dirs() {
    local -a all_pkg_dirs=("$@")
    local -A dir_counts

    for pkg_dir in "${all_pkg_dirs[@]}"; do
        [[ -d "$pkg_dir" ]] || continue
        while IFS= read -r -d '' rel_dir; do
            [[ -z "$rel_dir" ]] && continue
            dir_counts["$rel_dir"]=$((${dir_counts["$rel_dir"]:-0} + 1))
        done < <(find "$pkg_dir" -mindepth 1 -type d \
            -not -path '*/.git/*' -not -name '.git' \
            -printf '%P\0' 2>/dev/null)
    done

    for dir_path in "${!dir_counts[@]}"; do
        if ((dir_counts["$dir_path"] >= 2)); then
            SHARED_DIRS["$dir_path"]=1
        fi
    done
}

backup_conflicts() {
    local pkg_dir="$1"
    local target="$2"
    local rel_prefix="${3:-}"

    for entry in "$pkg_dir"/.* "$pkg_dir"/*; do
        [[ -e "$entry" ]] || continue
        local name
        name="$(basename "$entry")"
        [[ "$name" == "." || "$name" == ".." ]] && continue

        local target_path="$target/$name"
        [[ -e "$target_path" ]] || continue # no conflict
        [[ -L "$target_path" ]] && continue # already a symlink, skip

        if [[ -f "$target_path" ]]; then
            local bak_path
            bak_path="$(next_backup_path "$target_path")"
            mv "$target_path" "$bak_path"
            info "  Backed up: $target_path -> $bak_path"
        elif [[ -d "$entry" && -d "$target_path" ]]; then
            local rel_path
            if [[ -n "$rel_prefix" ]]; then
                rel_path="$rel_prefix/$name"
            else
                rel_path="$name"
            fi

            if [[ -n "${SHARED_DIRS["$rel_path"]+_}" ]] || is_recurse_dir "$rel_path"; then
                # Shared directory (used by multiple packages) — descend
                backup_conflicts "$entry" "$target_path" "$rel_path"
            else
                # Package-owned directory — back up entirely
                local bak_path
                bak_path="$(next_backup_path "$target_path")"
                mv "$target_path" "$bak_path"
                info "  Backed up: $target_path -> $bak_path"
            fi
        fi
    done
}

DOTFILES_DIR="$HOME/.dotfiles"
DOTFILES_REPO="git@github.com:your-username/.dotfiles.git"

# ─── Phase 1: Clone dotfiles repo if missing ─────────────────────────────────

info "Phase 1: Dotfiles repository"
if [[ -d "$DOTFILES_DIR/.git" ]]; then
    ok "Dotfiles repo already exists at $DOTFILES_DIR"
else
    info "Dotfiles repo not found at $DOTFILES_DIR"
    info ""
    info "This will clone from: $DOTFILES_REPO"
    info "Make sure your SSH key is set up for GitHub."
    info "  - Check: ssh -T git@github.com"
    info "  - Setup: https://docs.github.com/en/authentication/connecting-to-github-with-ssh"
    info ""
    printf 'Is your git/SSH auth ready? (y/N): '
    read -r AUTH_READY
    if [[ ! "$AUTH_READY" =~ ^[Yy]$ ]]; then
        info "Please set up git auth and re-run this task."
        exit 0
    fi

    info "Cloning dotfiles..."
    git clone --recursive "$DOTFILES_REPO" "$DOTFILES_DIR"

    # Ensure tmux submodule is on master
    if [[ -d "$DOTFILES_DIR/tmux/.tmux" ]]; then
        info "Checking out tmux submodule to master..."
        cd "$DOTFILES_DIR/tmux/.tmux"
        git checkout master
    fi

    # Ensure nvim submodule is on custom_config
    if [[ -d "$DOTFILES_DIR/nvim/.config/nvim" ]]; then
        info "Checking out nvim submodule to custom_config..."
        cd "$DOTFILES_DIR/nvim/.config/nvim"
        git checkout custom_config
    fi

    cd "$DOTFILES_DIR"
    git config submodule.recurse true
    ok_changed "Dotfiles repo cloned and configured"
fi

# ─── Phase 2: Verify stow is available ───────────────────────────────────────

info "Phase 2: Verify stow"
command -v stow &>/dev/null || fail "stow not found. Run: mise run install:stow"
ok "stow available: $(command -v stow)"

# ─── Phase 3: Detect device type ─────────────────────────────────────────────

DEVICE_TYPE_FILE="$DOTFILES_DIR/.device-type"

info "Phase 3: Detect device type"
if [[ -n "${DOTFILES_DEVICE:-}" ]]; then
    info "Using DOTFILES_DEVICE from environment: $DOTFILES_DEVICE"
elif [[ -f "$DEVICE_TYPE_FILE" ]]; then
    DOTFILES_DEVICE="$(<"$DEVICE_TYPE_FILE")"
    info "Using persisted device type: $DOTFILES_DEVICE"
else
    if ls /sys/class/power_supply/BAT* &>/dev/null 2>&1; then
        DOTFILES_DEVICE="laptop"
    else
        DOTFILES_DEVICE="desktop"
    fi
    info "Auto-detected device type: $DOTFILES_DEVICE"
    printf 'Device type is "%s". Change? [l]aptop / [d]esktop / [n]one / Enter to keep: ' "$DOTFILES_DEVICE"
    read -r CHANGE_DEVICE
    case "${CHANGE_DEVICE,,}" in
    l | laptop)
        DOTFILES_DEVICE="laptop"
        info "Switched to: laptop"
        ;;
    d | desktop)
        DOTFILES_DEVICE="desktop"
        info "Switched to: desktop"
        ;;
    n | none)
        DOTFILES_DEVICE="none"
        info "Switched to: none (device-specific configs will be skipped)"
        ;;
    "") ;; # keep current
    *) warn "Unrecognized input '$CHANGE_DEVICE', keeping: $DOTFILES_DEVICE" ;;
    esac
fi

ok "Device type: $DOTFILES_DEVICE"

# Persist device type for future runs
printf '%s' "$DOTFILES_DEVICE" >"$DEVICE_TYPE_FILE"

# ─── Phase 3.5: Manage stow exclusions ──────────────────────────────────────

STOW_EXCLUDE_FILE="$DOTFILES_DIR/.stow-exclude"
ALL_COMMON_PACKAGES=(bash fzf git gnome_themes gpg zsh tmux bat yazi mise nvim gh gh-dash claude ghostty)
ALL_DEVICE_PACKAGES=(ssh p10k)

info "Phase 3.5: Stow exclusions"

# Create .stow-exclude with header if missing
if [[ ! -f "$STOW_EXCLUDE_FILE" ]]; then
    cat > "$STOW_EXCLUDE_FILE" <<'HEADER'
# Stow package exclusion list (per-machine, gitignored)
# Add one package name per line to skip it during setup:dotfiles
# Available packages: bash fzf git gnome_themes gpg zsh tmux bat yazi mise nvim gh gh-dash claude ghostty
# Device packages: ssh p10k
HEADER
    info "Created $STOW_EXCLUDE_FILE — edit to skip packages on this machine"
fi

# Read current exclusions from file (strip comments and blank lines)
read_exclusions() {
    EXCLUDED=()
    while IFS= read -r line; do
        line="${line%%#*}"          # strip inline comments
        line="${line// /}"          # strip spaces
        [[ -z "$line" ]] && continue
        EXCLUDED+=("$line")
    done < "$STOW_EXCLUDE_FILE"
}

# Write exclusions back to file (preserves header comments)
write_exclusions() {
    # Keep only comment/blank lines from original, then append exclusions
    local tmpfile
    tmpfile="$(mktemp)"
    grep -E '^\s*(#|$)' "$STOW_EXCLUDE_FILE" > "$tmpfile" || true
    for pkg in "${EXCLUDED[@]}"; do
        printf '%s\n' "$pkg" >> "$tmpfile"
    done
    mv "$tmpfile" "$STOW_EXCLUDE_FILE"
}

# Check if a value is in an array
in_array() {
    local needle="$1"; shift
    for item in "$@"; do
        [[ "$item" == "$needle" ]] && return 0
    done
    return 1
}

# Unstow a package and restore backups if any exist
unstow_package() {
    local pkg="$1"
    local is_device="${2:-false}"

    if [[ "$is_device" == "true" ]]; then
        if [[ -d "$DOTFILES_DIR/$pkg/$DOTFILES_DEVICE" ]]; then
            stow -D -d "$DOTFILES_DIR/$pkg" -t "$HOME" "$DOTFILES_DEVICE" 2>/dev/null || true
            info "  Unstowed device package: $pkg ($DOTFILES_DEVICE)"
        fi
    else
        if [[ -d "$DOTFILES_DIR/$pkg" ]]; then
            stow -D -d "$DOTFILES_DIR" -t "$HOME" "$pkg" 2>/dev/null || true
            info "  Unstowed package: $pkg"
        fi
    fi

    # Restore backups: find .bak files that belong to this package
    local pkg_dir
    if [[ "$is_device" == "true" ]]; then
        pkg_dir="$DOTFILES_DIR/$pkg/$DOTFILES_DEVICE"
    else
        pkg_dir="$DOTFILES_DIR/$pkg"
    fi
    [[ -d "$pkg_dir" ]] || return 0

    while IFS= read -r -d '' rel_path; do
        [[ -z "$rel_path" ]] && continue
        local target="$HOME/$rel_path"
        # Find the highest numbered backup
        local restore_from=""
        local i=1
        if [[ -e "$target.bak" ]]; then
            restore_from="$target.bak"
        fi
        while [[ -e "$target.bak.$i" ]]; do
            restore_from="$target.bak.$i"
            ((i++))
        done
        if [[ -n "$restore_from" ]]; then
            mv "$restore_from" "$target"
            info "  Restored: $restore_from -> $target"
        fi
    done < <(find "$pkg_dir" -mindepth 1 \( -type f -o -type l \) \
        -not -path '*/.git/*' -not -name '.git' \
        -printf '%P\0' 2>/dev/null)
}

# Interactive exclusion management loop
while true; do
    read_exclusions

    if ((${#EXCLUDED[@]} > 0)); then
        info "Currently excluded: ${EXCLUDED[*]}"
    else
        info "No packages currently excluded"
    fi

    printf 'Modify exclusions? [a]dd / [r]emove / Enter to keep: '
    read -r MODIFY_CHOICE

    case "${MODIFY_CHOICE,,}" in
    a | add)
        # Build list of available (non-excluded) packages
        AVAILABLE=()
        for pkg in "${ALL_COMMON_PACKAGES[@]}" "${ALL_DEVICE_PACKAGES[@]}"; do
            in_array "$pkg" "${EXCLUDED[@]}" || AVAILABLE+=("$pkg")
        done
        if ((${#AVAILABLE[@]} == 0)); then
            warn "All packages are already excluded"
            continue
        fi
        info "Available packages:"
        for i in "${!AVAILABLE[@]}"; do
            printf '  %d) %s\n' "$((i + 1))" "${AVAILABLE[$i]}"
        done
        printf 'Enter numbers to exclude (space-separated), or Enter to cancel: '
        read -r ADD_CHOICES
        [[ -z "$ADD_CHOICES" ]] && continue
        for choice in $ADD_CHOICES; do
            if [[ "$choice" =~ ^[0-9]+$ ]] && ((choice >= 1 && choice <= ${#AVAILABLE[@]})); then
                local_pkg="${AVAILABLE[$((choice - 1))]}"
                EXCLUDED+=("$local_pkg")
                info "  Added: $local_pkg"
            else
                warn "  Invalid selection: $choice"
            fi
        done
        write_exclusions
        ;;
    r | remove)
        if ((${#EXCLUDED[@]} == 0)); then
            warn "No packages to remove from exclusions"
            continue
        fi
        info "Currently excluded packages:"
        for i in "${!EXCLUDED[@]}"; do
            printf '  %d) %s\n' "$((i + 1))" "${EXCLUDED[$i]}"
        done
        printf 'Enter numbers to un-exclude (space-separated), or Enter to cancel: '
        read -r REMOVE_CHOICES
        [[ -z "$REMOVE_CHOICES" ]] && continue
        TO_REMOVE=()
        for choice in $REMOVE_CHOICES; do
            if [[ "$choice" =~ ^[0-9]+$ ]] && ((choice >= 1 && choice <= ${#EXCLUDED[@]})); then
                TO_REMOVE+=("${EXCLUDED[$((choice - 1))]}")
                info "  Removed: ${EXCLUDED[$((choice - 1))]}"
            else
                warn "  Invalid selection: $choice"
            fi
        done
        # Rebuild EXCLUDED without removed items
        NEW_EXCLUDED=()
        for pkg in "${EXCLUDED[@]}"; do
            in_array "$pkg" "${TO_REMOVE[@]}" || NEW_EXCLUDED+=("$pkg")
        done
        EXCLUDED=("${NEW_EXCLUDED[@]}")
        write_exclusions
        ;;
    "")
        break
        ;;
    *)
        warn "Unrecognized input '$MODIFY_CHOICE'"
        ;;
    esac
done

# Unstow any newly-excluded packages that have symlinks in $HOME
read_exclusions
for pkg in "${EXCLUDED[@]}"; do
    if in_array "$pkg" "${ALL_DEVICE_PACKAGES[@]}"; then
        unstow_package "$pkg" true
    else
        unstow_package "$pkg" false
    fi
done

if ((${#EXCLUDED[@]} > 0)); then
    ok "Exclusions applied: ${EXCLUDED[*]}"
else
    ok "No exclusions"
fi

# ─── Precompute shared directories ───────────────────────────────────────────

# Filter packages based on exclusions
COMMON_PACKAGES=()
for pkg in "${ALL_COMMON_PACKAGES[@]}"; do
    in_array "$pkg" "${EXCLUDED[@]}" || COMMON_PACKAGES+=("$pkg")
done
DEVICE_PACKAGES=()
for pkg in "${ALL_DEVICE_PACKAGES[@]}"; do
    in_array "$pkg" "${EXCLUDED[@]}" || DEVICE_PACKAGES+=("$pkg")
done

ALL_PKG_DIRS=()
for pkg in "${COMMON_PACKAGES[@]}"; do
    ALL_PKG_DIRS+=("$DOTFILES_DIR/$pkg")
done
for pkg in "${DEVICE_PACKAGES[@]}"; do
    for variant in laptop desktop; do
        ALL_PKG_DIRS+=("$DOTFILES_DIR/$pkg/$variant")
    done
done

compute_shared_dirs "${ALL_PKG_DIRS[@]}"

# ─── Phase 4: Deploy common packages ─────────────────────────────────────────

info "Phase 4: Deploy common stow packages"

for pkg in "${COMMON_PACKAGES[@]}"; do
    if [[ ! -d "$DOTFILES_DIR/$pkg" ]]; then
        warn "Package directory '$pkg' not found, skipping"
        continue
    fi
    backup_conflicts "$DOTFILES_DIR/$pkg" "$HOME"
    stow -d "$DOTFILES_DIR" -R -t "$HOME" "$pkg" 2>&1 | { grep -v '^BUG in find_stowed_path' || true; } | while read -r line; do
        info "  $line"
    done
done
ok_changed "Common packages deployed: ${COMMON_PACKAGES[*]}"

# ─── Phase 5: Deploy device-specific packages ────────────────────────────────

info "Phase 5: Deploy device-specific packages ($DOTFILES_DEVICE)"
if [[ "$DOTFILES_DEVICE" == "none" ]]; then
    info "  Skipping device-specific packages (device type is none)"
else
    for pkg in "${DEVICE_PACKAGES[@]}"; do
        if [[ -d "$DOTFILES_DIR/$pkg/$DOTFILES_DEVICE" ]]; then
            backup_conflicts "$DOTFILES_DIR/$pkg/$DOTFILES_DEVICE" "$HOME"
            stow -d "$DOTFILES_DIR/$pkg" -R -t "$HOME" "$DOTFILES_DEVICE" 2>&1 | { grep -v '^BUG in find_stowed_path' || true; } | while read -r line; do
                info "  $line"
            done
            ok_changed "$pkg config deployed ($DOTFILES_DEVICE)"
        else
            warn "$pkg config directory not found: $pkg/$DOTFILES_DEVICE"
        fi
    done
fi

# ─── Phase 6: Ensure tmux submodule is on master ─────────────────────────────

info "Phase 6: Tmux submodule"
if [[ -e "$DOTFILES_DIR/tmux/.tmux/.git" ]]; then
    cd "$DOTFILES_DIR/tmux/.tmux"
    CURRENT_BRANCH="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
    if [[ "$CURRENT_BRANCH" != "master" ]]; then
        git checkout master
        ok_changed "tmux submodule checked out to master"
    else
        ok "tmux submodule already on master"
    fi
else
    warn "tmux submodule not found at tmux/.tmux"
fi

# ─── Phase 7: Ensure nvim submodule is on custom_config ──────────────────────

info "Phase 7: Neovim submodule"
if [[ -e "$DOTFILES_DIR/nvim/.config/nvim/.git" ]]; then
    cd "$DOTFILES_DIR/nvim/.config/nvim"
    CURRENT_BRANCH="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
    if [[ "$CURRENT_BRANCH" != "custom_config" ]]; then
        git checkout custom_config
        ok_changed "nvim submodule checked out to custom_config"
    else
        ok "nvim submodule already on custom_config"
    fi
else
    warn "nvim submodule not found at nvim/.config/nvim"
fi

# ─── Phase 8: Verify ─────────────────────────────────────────────────────────

info "Phase 8: Verification"
VERIFY_FILES=("$HOME/.zshrc" "$HOME/.gitconfig" "$HOME/.config/nvim/init.lua" "$HOME/.claude/settings.json")
if [[ "$DOTFILES_DEVICE" == "laptop" || "$DOTFILES_DEVICE" == "desktop" ]]; then
    VERIFY_FILES+=("$HOME/.ssh/config" "$HOME/.p10k.zsh")
fi
for f in "${VERIFY_FILES[@]}"; do
    if [[ -L "$f" || -f "$f" ]]; then
        ok "  $f"
    else
        warn "  $f not found"
    fi
done

printf '\n'
info "============================================"
info "  dotfiles deployment complete!"
info "  Device: $DOTFILES_DEVICE"
info "============================================"
printf '\n'
