#!/usr/bin/env bash
#MISE description="Run powerlevel10k interactive configuration wizard"
#MISE raw=true
set -eo pipefail

# ─── Helpers ───────────────────────────────────────────────────────────────────

info()  { printf '\033[1;34m[INFO]\033[0m   %s\n' "$*"; }
warn()  { printf '\033[1;33m[WARN]\033[0m   %s\n' "$*"; }
ok()    { printf '\033[1;32m[ OK ]\033[0m   %s\n' "$*"; }
ok_changed() { printf '\033[1;32m[ OK ] \033[1;32m●\033[0m %s\n' "$*"; }

# Resolve symlink target if present, otherwise return path as-is
resolve_file() {
    if [[ -L "$1" ]]; then
        readlink -f "$1"
    else
        echo "$1"
    fi
}

if [[ ! -d "${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}/themes/powerlevel10k" ]]; then
    echo "Error: powerlevel10k not installed. Run 'mise run setup:zsh' first."
    exit 1
fi

# ─── Ensure ZSH_THEME is set to p10k ─────────────────────────────────────────

ZSHRC="$(resolve_file "$HOME/.zshrc")"
if [[ -f "$ZSHRC" ]]; then
    if grep -q '^ZSH_THEME="powerlevel10k/powerlevel10k"' "$ZSHRC" 2>/dev/null; then
        ok "ZSH_THEME already set to powerlevel10k"
    else
        if grep -q '^ZSH_THEME=' "$ZSHRC"; then
            sed -i 's/^ZSH_THEME=.*/ZSH_THEME="powerlevel10k\/powerlevel10k"/' "$ZSHRC"
            ok_changed "Updated ZSH_THEME to powerlevel10k in .zshrc"
        else
            # Insert before 'source $ZSH/oh-my-zsh.sh' if present, otherwise append
            if grep -q 'source.*oh-my-zsh.sh' "$ZSHRC"; then
                sed -i '/source.*oh-my-zsh.sh/i ZSH_THEME="powerlevel10k/powerlevel10k"' "$ZSHRC"
            else
                printf '\nZSH_THEME="powerlevel10k/powerlevel10k"\n' >> "$ZSHRC"
            fi
            ok_changed "Added ZSH_THEME=powerlevel10k to .zshrc"
        fi
    fi
else
    warn "No .zshrc found — p10k configure may not work"
fi

printf 'Would you like to configure powerlevel10k now? (y/N): '
read -r CONFIGURE_P10K
if [[ "$CONFIGURE_P10K" =~ ^[Yy]$ ]]; then
    zsh -i -c 'p10k configure'
else
    echo "Skipped. You can run 'mise run setup:p10k-configure' later."
fi

# ─── OS icon prompt (interactive) ────────────────────────────────────────────

info "OS icon in p10k"
printf 'Would you like to change the OS icon in p10k? (y/N): '
read -r CHANGE_ICON
if [[ "$CHANGE_ICON" =~ ^[Yy]$ ]]; then
    printf 'Browse icons at https://www.nerdfonts.com/cheat-sheet\n'
    printf 'Paste your desired icon: '
    read -r NEW_ICON
    if [[ -n "$NEW_ICON" ]]; then
        P10K_FILE="$(resolve_file "$HOME/.p10k.zsh")"
        if [[ -f "$P10K_FILE" ]]; then
            # Use awk to safely handle special characters in the icon
            awk -v icon="$NEW_ICON" '
                /POWERLEVEL9K_OS_ICON_CONTENT_EXPANSION/ { next }
                /POWERLEVEL9K_OS_ICON_BACKGROUND/ {
                    print
                    print "  typeset -g POWERLEVEL9K_OS_ICON_CONTENT_EXPANSION=\047" icon "\047"
                    next
                }
                { print }
            ' "$P10K_FILE" > "${P10K_FILE}.tmp" && mv -f "${P10K_FILE}.tmp" "$P10K_FILE"
            ok_changed "OS icon updated in .p10k.zsh"
        else
            warn ".p10k.zsh not found — run p10k configure first"
        fi
    fi
else
    ok "OS icon unchanged"
fi
