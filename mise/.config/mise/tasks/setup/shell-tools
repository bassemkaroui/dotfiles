#!/usr/bin/env bash
#MISE description="Setup shell integrations for installed mise-managed tools"
#MISE raw=true
set -eo pipefail

# ─── Helpers ───────────────────────────────────────────────────────────────────

info()  { printf '\033[1;34m[INFO]\033[0m   %s\n' "$*"; }
warn()  { printf '\033[1;33m[WARN]\033[0m   %s\n' "$*"; }
ok()    { printf '\033[1;32m[ OK ]\033[0m   %s\n' "$*"; }
ok_changed() { printf '\033[1;32m[ OK ] \033[1;32m●\033[0m %s\n' "$*"; }
fail()  { printf '\033[1;31m[FAIL]\033[0m   %s\n' "$*"; exit 1; }

resolve_file() {
    if [[ -L "$1" ]]; then
        readlink -f "$1"
    else
        echo "$1"
    fi
}

ZSH_CUSTOM="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}"
ZSHRC="$(resolve_file "$HOME/.zshrc")"

# ─── Dynamic block builder ────────────────────────────────────────────────────

build_shell_tools_block() {
    local block=""
    block+="# >>> mise-shell-tools (managed by mise run setup:shell-tools — do not edit)"$'\n'

    # ── History (always included) ──
    block+=$'\n'
    block+="# ── History ──"$'\n'
    block+="HISTSIZE=50000"$'\n'
    block+="HISTFILE=~/.zsh_history"$'\n'
    block+='SAVEHIST=$HISTSIZE'$'\n'
    block+="HISTDUP=erase"$'\n'
    block+="setopt appendhistory"$'\n'
    block+="setopt sharehistory"$'\n'
    block+="setopt hist_ignore_space"$'\n'
    block+="setopt hist_ignore_all_dups"$'\n'
    block+="setopt hist_save_no_dups"$'\n'
    block+="setopt hist_ignore_dups"$'\n'
    block+="setopt hist_find_no_dups"$'\n'

    # ── Completion zstyles (always included, eza-dependent lines conditional) ──
    block+=$'\n'
    block+="# ── Completion zstyles ──"$'\n'
    block+="zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'"$'\n'
    block+="zstyle ':completion:*:git-checkout:*' sort false"$'\n'
    block+='zstyle '"'"':completion:*'"'"' list-colors ${(s.:.)LS_COLORS}'$'\n'
    block+="zstyle ':completion:*' menu no"$'\n'
    if command -v eza &>/dev/null; then
        block+="zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza --color=always \$realpath'"$'\n'
        block+="zstyle ':fzf-tab:complete:__zoxide_z:*' fzf-preview 'eza --color=always \$realpath'"$'\n'
    fi

    # ── Zoxide ──
    if command -v zoxide &>/dev/null; then
        block+=$'\n'
        block+="# ── Zoxide ──"$'\n'
        block+='eval "$(zoxide init --cmd cd zsh)"'$'\n'
    fi

    # ── FZF + fd ──
    if command -v fzf &>/dev/null && command -v fd &>/dev/null; then
        block+=$'\n'
        block+="# ── FZF + fd ──"$'\n'
        block+='[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh'$'\n'
        block+='export FZF_DEFAULT_COMMAND="fd --hidden --strip-cwd-prefix --exclude .git"'$'\n'
        block+='export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"'$'\n'
        block+='export FZF_ALT_C_COMMAND="fd --type=d --hidden --strip-cwd-prefix --exclude .git"'$'\n'
        block+=$'\n'
        block+='_fzf_compgen_path() {'$'\n'
        block+='  fd --hidden --exclude .git . "$1"'$'\n'
        block+='}'$'\n'
        block+=$'\n'
        block+='_fzf_compgen_dir() {'$'\n'
        block+='  fd --type=d --hidden --exclude .git . "$1"'$'\n'
        block+='}'$'\n'
    fi

    # ── Bat ──
    if command -v bat &>/dev/null; then
        block+=$'\n'
        block+="# ── Bat ──"$'\n'
        block+="export BAT_THEME=tokyonight_night"$'\n'
        block+="alias cat=bat"$'\n'
    fi

    # ── FZF + Eza + Bat integration ──
    if command -v fzf &>/dev/null && command -v eza &>/dev/null && command -v bat &>/dev/null; then
        block+=$'\n'
        block+="# ── FZF + Eza + Bat integration ──"$'\n'
        block+='export FZF_CTRL_T_OPTS="--preview '"'"'bat -n --color=always --line-range :500 {}'"'"'"'$'\n'
        block+='export FZF_ALT_C_OPTS="--preview '"'"'eza --tree --color=always {} | head -200'"'"'"'$'\n'
        block+=$'\n'
        block+='_fzf_comprun() {'$'\n'
        block+='  local command=$1'$'\n'
        block+='  shift'$'\n'
        block+=$'\n'
        block+='  case "$command" in'$'\n'
        block+="    cd)           fzf --preview 'eza --tree --color=always {} | head -200' "'"$@"'" ;;"$'\n'
        block+="    export|unset) fzf --preview \"eval 'echo \$'{}\"         \"\$@\" ;;"$'\n'
        block+="    ssh)          fzf --preview 'dig {}'                   "'"$@"'" ;;"$'\n'
        block+='    *)            fzf --preview "bat -n --color=always --line-range :500 {}" "$@" ;;'$'\n'
        block+='  esac'$'\n'
        block+='}'$'\n'
    fi

    # ── Neovim ──
    if command -v nvim &>/dev/null; then
        block+=$'\n'
        block+="# ── Neovim ──"$'\n'
        block+='alias vim="nvim"'$'\n'
        block+='alias v="nvim"'$'\n'
        block+="export EDITOR=nvim"$'\n'
        block+='export SUDO_EDITOR=$(which nvim)'$'\n'
    fi

    # ── UV completions ──
    if command -v uv &>/dev/null && command -v uvx &>/dev/null; then
        block+=$'\n'
        block+="# ── UV completions ──"$'\n'
        block+='eval "$(uvx --generate-shell-completion zsh)"'$'\n'
        block+='eval "$(uv generate-shell-completion zsh)"'$'\n'
    fi

    # ── Python PATH fix for Neovim ──
    if command -v nvim &>/dev/null && command -v python3 &>/dev/null; then
        block+=$'\n'
        block+="# ── Python PATH fix for Neovim ──"$'\n'
        block+='export PATH=$(dirname $(realpath $(which python3))):$PATH'$'\n'
    fi

    # ── Yazi ──
    if command -v yazi &>/dev/null; then
        block+=$'\n'
        block+="# ── Yazi ──"$'\n'
        block+='function y() {'$'\n'
        block+=$'\t''local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd'$'\n'
        block+=$'\t''yazi "$@" --cwd-file="$tmp"'$'\n'
        block+=$'\t''if cwd="$(command cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then'$'\n'
        block+=$'\t\t''builtin cd -- "$cwd"'$'\n'
        block+=$'\t''fi'$'\n'
        block+=$'\t''rm -f -- "$tmp"'$'\n'
        block+='}'$'\n'
    fi

    block+="# <<< mise-shell-tools"
    printf '%s' "$block"
}

# ─── Phase 1: Bat theme ──────────────────────────────────────────────────────

info "Phase 1: Bat theme"
if ! command -v bat &>/dev/null; then
    warn "bat not found — skipping theme setup"
else
    BAT_THEMES_DIR="$(bat --config-dir)/themes"
    BAT_THEME_FILE="$BAT_THEMES_DIR/tokyonight_night.tmTheme"
    mkdir -p "$BAT_THEMES_DIR"
    if [[ -f "$BAT_THEME_FILE" ]]; then
        ok "Bat tokyonight_night theme already installed"
    else
        info "Downloading tokyonight_night bat theme..."
        curl -fSL -o "$BAT_THEME_FILE" \
            "https://raw.githubusercontent.com/folke/tokyonight.nvim/main/extras/sublime/tokyonight_night.tmTheme"
        ok_changed "Installed tokyonight_night bat theme"
    fi
    bat cache --build >/dev/null 2>&1
fi

# ─── Phase 2: fzf-tab plugin ─────────────────────────────────────────────────

info "Phase 2: fzf-tab plugin"
if ! command -v fzf &>/dev/null; then
    warn "fzf not found — skipping fzf-tab plugin"
else
    FZF_TAB_DIR="$ZSH_CUSTOM/plugins/fzf-tab"
    if [[ -d "$FZF_TAB_DIR" ]]; then
        ok "fzf-tab plugin already installed"
    else
        info "Cloning fzf-tab..."
        git clone --depth=1 https://github.com/Aloxaf/fzf-tab "$FZF_TAB_DIR"
        ok_changed "Installed fzf-tab"
    fi

    # Ensure fzf-tab is in the plugins=(...) line
    if grep -q '^plugins=(' "$ZSHRC" 2>/dev/null; then
        if ! grep '^plugins=(' "$ZSHRC" | grep -qw 'fzf-tab'; then
            info "Adding fzf-tab to plugins line..."
            sed -i "s/^plugins=(\(.*\))/plugins=(\1 fzf-tab)/" "$ZSHRC"
            ok_changed "Added fzf-tab to plugins"
        else
            ok "fzf-tab already in plugins list"
        fi
    else
        warn "No plugins=() line found in .zshrc — fzf-tab not added"
    fi
fi

# ─── Build desired block & check if update needed ────────────────────────────

SHELL_TOOLS_BLOCK="$(build_shell_tools_block)"

EXISTING_BLOCK=""
if grep -q '# >>> mise-shell-tools' "$ZSHRC" 2>/dev/null; then
    EXISTING_BLOCK=$(sed -n '/^# >>> mise-shell-tools/,/^# <<< mise-shell-tools/p' "$ZSHRC")
fi

if [[ "$EXISTING_BLOCK" == "$SHELL_TOOLS_BLOCK" ]]; then
    # Block is already exactly right — skip Phase 3 & 4 entirely
    info "Phase 3: Clean up old manual config lines"
    ok "No old manual lines to clean (managed block exists)"
    info "Phase 4: Insert managed block"
    ok "mise-shell-tools block already up-to-date in .zshrc"
else

# ─── Phase 3: Clean up old manual config lines ───────────────────────────────

info "Phase 3: Clean up old manual config lines"

# Remove any previous managed block and its trailing blank line
if grep -q '# >>> mise-shell-tools' "$ZSHRC" 2>/dev/null; then
    sed -i '/^# >>> mise-shell-tools/,/^# <<< mise-shell-tools/d' "$ZSHRC"
    # Remove the blank line left behind after block deletion
    sed -i '/^$/{N;/^\n$/d}' "$ZSHRC"
    ok_changed "Removed previous mise-shell-tools block"
fi

# History settings
sed -i '/^HISTSIZE=/d' "$ZSHRC"
sed -i '/^HISTFILE=/d' "$ZSHRC"
sed -i '/^SAVEHIST=/d' "$ZSHRC"
sed -i '/^HISTDUP=/d' "$ZSHRC"
sed -i '/^setopt appendhistory$/d' "$ZSHRC"
sed -i '/^setopt sharehistory$/d' "$ZSHRC"
sed -i '/^setopt hist_ignore_space$/d' "$ZSHRC"
sed -i '/^setopt hist_ignore_all_dups$/d' "$ZSHRC"
sed -i '/^setopt hist_save_no_dups$/d' "$ZSHRC"
sed -i '/^setopt hist_ignore_dups$/d' "$ZSHRC"
sed -i '/^setopt hist_find_no_dups$/d' "$ZSHRC"

# Completion zstyles
sed -i "/^zstyle ':completion:\*' matcher-list/d" "$ZSHRC"
sed -i "/^# disable sort when completing/d" "$ZSHRC"
sed -i "/^zstyle ':completion:\*:git-checkout:\*' sort false/d" "$ZSHRC"
sed -i "/^# set list-colors to enable filename colorizing/d" "$ZSHRC"
sed -i "/^zstyle ':completion:\*' list-colors/d" "$ZSHRC"
sed -i "/^# force zsh not to show completion menu/d" "$ZSHRC"
sed -i "/^zstyle ':completion:\*' menu no/d" "$ZSHRC"
sed -i "/^zstyle ':fzf-tab:complete:cd:\*'/d" "$ZSHRC"
sed -i "/^zstyle ':fzf-tab:complete:__zoxide_z:\*'/d" "$ZSHRC"

# Zoxide
sed -i '/^eval "\$(zoxide init/d' "$ZSHRC"

# FZF section
sed -i '/^# ----------- FZF/d' "$ZSHRC"
sed -i '/^\[ -f ~\/\.fzf\.zsh \] && source/d' "$ZSHRC"
sed -i '/^# -- Use fd instead of fzf/d' "$ZSHRC"
sed -i '/^export FZF_DEFAULT_COMMAND=/d' "$ZSHRC"
sed -i '/^export FZF_CTRL_T_COMMAND=/d' "$ZSHRC"
sed -i '/^export FZF_ALT_C_COMMAND=/d' "$ZSHRC"
sed -i '/^# Use fd.*for listing path candidates/d' "$ZSHRC"
sed -i '/^# - The first argument to the function/d' "$ZSHRC"
sed -i '/^# - See the source code/d' "$ZSHRC"
# Multi-line function: _fzf_compgen_path
sed -i '/^_fzf_compgen_path()/,/^}/d' "$ZSHRC"
# Multi-line function: _fzf_compgen_dir
sed -i '/^# Use fd to generate the list for directory completion/d' "$ZSHRC"
sed -i '/^_fzf_compgen_dir()/,/^}/d' "$ZSHRC"

# Bat section
sed -i '/^# ------------ bat/d' "$ZSHRC"
sed -i '/^export BAT_THEME=/d' "$ZSHRC"
sed -i '/^alias cat=bat$/d' "$ZSHRC"

# FZF+Eza+Bat section
sed -i '/^# ---------- fzf with eza and bat/d' "$ZSHRC"
sed -i '/^export FZF_CTRL_T_OPTS=/d' "$ZSHRC"
sed -i '/^export FZF_ALT_C_OPTS=/d' "$ZSHRC"
sed -i '/^# Advanced customization of fzf options/d' "$ZSHRC"
sed -i '/^# - The first argument to the function is the name/d' "$ZSHRC"
sed -i '/^# - You should make sure to pass the rest/d' "$ZSHRC"
# Multi-line function: _fzf_comprun
sed -i '/^_fzf_comprun()/,/^}/d' "$ZSHRC"

# Neovim aliases and editor
sed -i '/^alias vim="nvim"$/d' "$ZSHRC"
sed -i '/^alias v="nvim"$/d' "$ZSHRC"
sed -i '/^export EDITOR=nvim$/d' "$ZSHRC"
sed -i '/^# export SUDO_EDITOR=\/opt\/nvim/d' "$ZSHRC"
sed -i '/^export SUDO_EDITOR=\$(which nvim)$/d' "$ZSHRC"

# UV completions
sed -i '/^eval "\$(uvx --generate-shell-completion zsh)"/d' "$ZSHRC"
sed -i '/^eval "\$(uv generate-shell-completion zsh)"/d' "$ZSHRC"
sed -i '/^fpath+=~\/\.zfunc; autoload -Uz compinit; compinit$/d' "$ZSHRC"

# Yazi function
sed -i '/^# yazi$/d' "$ZSHRC"
sed -i '/^function y()/,/^}/d' "$ZSHRC"

# Python PATH fix for neovim
sed -i '/^# Fix for Neovim when working with managed pythons/d' "$ZSHRC"
sed -i '/^export PATH=\$(dirname \$(realpath \$(which python3))):$PATH$/d' "$ZSHRC"

# Collapse blank-line clusters
sed -i '/^$/N;/^\n$/d' "$ZSHRC"

ok_changed "Cleaned up old manual config lines"

# ─── Phase 4: Insert managed block ───────────────────────────────────────────

info "Phase 4: Insert managed block"

# Insert after source $ZSH/oh-my-zsh.sh
if grep -q 'source \$ZSH/oh-my-zsh.sh' "$ZSHRC" 2>/dev/null || grep -q 'source $ZSH/oh-my-zsh.sh' "$ZSHRC" 2>/dev/null; then
    awk -v block="$SHELL_TOOLS_BLOCK" '
        /source \$ZSH\/oh-my-zsh\.sh/ || /source \$\{ZSH\}\/oh-my-zsh\.sh/ {
            print
            print ""
            print block
            next
        }
        { print }
    ' "$ZSHRC" > "${ZSHRC}.tmp" && mv -f "${ZSHRC}.tmp" "$ZSHRC"
    ok_changed "Inserted mise-shell-tools block after oh-my-zsh source"
else
    # Fallback: append to end
    printf '\n%s\n' "$SHELL_TOOLS_BLOCK" >> "$ZSHRC"
    ok_changed "Appended mise-shell-tools block to end of .zshrc"
fi

# end of block-changed branch
fi

# ─── Phase 5: Verification ───────────────────────────────────────────────────

info "Phase 5: Verification"
VERIFY_OK=true

if grep -q '# >>> mise-shell-tools' "$ZSHRC"; then
    ok "mise-shell-tools block present in .zshrc"
else
    fail "mise-shell-tools block NOT found in .zshrc"
    VERIFY_OK=false
fi

if command -v bat &>/dev/null; then
    BAT_THEMES_DIR="$(bat --config-dir)/themes"
    if [[ -f "$BAT_THEMES_DIR/tokyonight_night.tmTheme" ]]; then
        ok "Bat tokyonight_night theme file exists"
    else
        warn "Bat theme file not found"
        VERIFY_OK=false
    fi
fi

if command -v fzf &>/dev/null; then
    if [[ -d "$ZSH_CUSTOM/plugins/fzf-tab" ]]; then
        ok "fzf-tab plugin directory exists"
    else
        warn "fzf-tab plugin directory not found"
        VERIFY_OK=false
    fi
fi

# ─── Done ─────────────────────────────────────────────────────────────────────

printf '\n'
info "============================================"
info "  shell-tools setup complete!"
info "============================================"
info "Next steps:"
info "  1. Open a new terminal (or run: exec zsh)"
printf '\n'
