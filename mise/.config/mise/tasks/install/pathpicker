#!/usr/bin/env bash
#MISE description="Install Facebook PathPicker (fpp) via package manager or from source"
#MISE raw=true
set -eo pipefail

# ─── Helpers ───────────────────────────────────────────────────────────────────

TASK_NAME="install:pathpicker"
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../lib/helpers.sh"

# ─── Phase 1: Check if fpp is already installed ──────────────────────────────

info "Phase 1: Check if fpp is already installed"
INSTALL_DIR="$HOME/.local/opt/PathPicker"
if command -v fpp &>/dev/null; then
    if [[ -d "$INSTALL_DIR/.git" ]]; then
        info "fpp installed from source — checking for updates..."
        OLD_HEAD=$(git -C "$INSTALL_DIR" rev-parse HEAD)
        if git -C "$INSTALL_DIR" pull --quiet; then
            NEW_HEAD=$(git -C "$INSTALL_DIR" rev-parse HEAD)
            if [[ "$OLD_HEAD" != "$NEW_HEAD" ]]; then
                ok_changed "fpp updated from source: $(command -v fpp)"
            else
                ok "fpp already up to date: $(command -v fpp)"
            fi
        else
            warn "fpp update failed, continuing with existing version"
        fi
    else
        ok "fpp already installed via package manager: $(command -v fpp)"
    fi
    exit 0
fi

# ─── Phase 2: Try package manager with sudo ──────────────────────────────────

info "Phase 2: Try installing via package manager"
INSTALLED=false

if command -v sudo &>/dev/null; then
    if command -v nala &>/dev/null; then
        info "Trying: sudo nala install fpp -y"
        if sudo nala install fpp -y; then
            INSTALLED=true
        fi
    fi

    if [[ "$INSTALLED" == false ]] && command -v apt-get &>/dev/null; then
        info "Trying: sudo apt-get install -y fpp"
        if sudo apt-get install -y fpp; then
            INSTALLED=true
        fi
    fi
else
    info "sudo not available, skipping package manager install"
fi

if [[ "$INSTALLED" == true ]] && command -v fpp &>/dev/null; then
    ok_changed "fpp installed via package manager: $(command -v fpp)"
    exit 0
fi

# ─── Phase 3: Clone from GitHub and symlink ──────────────────────────────────

info "Phase 3: Installing PathPicker from GitHub into ~/.local/opt/"

command -v git &>/dev/null || fail "Cannot install PathPicker: 'git' not found."

BIN_LINK="$HOME/.local/bin/fpp"

mkdir -p "$HOME/.local/opt" "$HOME/.local/bin"

if [[ -d "$INSTALL_DIR" ]]; then
    info "Updating existing clone at $INSTALL_DIR..."
    git -C "$INSTALL_DIR" pull --quiet
else
    info "Cloning PathPicker to $INSTALL_DIR..."
    git clone --quiet https://github.com/facebook/PathPicker.git "$INSTALL_DIR"
fi

# Create symlink to the fpp entry point
ln -sf "$INSTALL_DIR/fpp" "$BIN_LINK"

# Ensure ~/.local/bin is in PATH for current session
if [[ ":$PATH:" != *":$HOME/.local/bin:"* ]]; then
    export PATH="$HOME/.local/bin:$PATH"
fi

# Persist ~/.local/bin in PATH for future sessions (if not already set via stow)
if [[ -f "$HOME/.zprofile" ]]; then
    if ! grep -q '\.local/bin' "$HOME/.zprofile" 2>/dev/null; then
        echo 'export PATH="$HOME/.local/bin:$PATH"' >> "$HOME/.zprofile"
    fi
else
    echo 'export PATH="$HOME/.local/bin:$PATH"' > "$HOME/.zprofile"
fi

# ─── Phase 4: Verify ─────────────────────────────────────────────────────────

info "Phase 4: Verify installation"
if command -v fpp &>/dev/null; then
    ok_changed "PathPicker (fpp) installed from source to $BIN_LINK"
else
    fail "PathPicker installation failed — fpp not found in PATH"
fi

printf '\n'
info "============================================"
info "  PathPicker installation complete!"
info "============================================"
printf '\n'
