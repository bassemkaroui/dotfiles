#!/usr/bin/env bash
#MISE description="Install nala, a friendlier apt frontend"
#MISE raw=true
set -eo pipefail

info()       { printf '\033[1;34m[INFO]\033[0m   %s\n' "$*"; }
warn()       { printf '\033[1;33m[WARN]\033[0m   %s\n' "$*"; }
ok()         { printf '\033[1;32m[ OK ]\033[0m   %s\n' "$*"; }
ok_changed() { printf '\033[1;32m[ OK ]\033[0m \033[1;32m●\033[0m %s\n' "$*"; }

if command -v nala &>/dev/null; then
  ok "nala already installed: $(command -v nala)"
  exit 0
fi

info "Installing nala via apt..."

if sudo -n apt-get install -y nala 2>/dev/null || sudo apt-get install -y nala; then
  ok_changed "nala installed successfully"
else
  warn "Could not install nala (no sudo access or nala not in apt repos). Skipping."
fi
