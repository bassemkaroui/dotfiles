#!/usr/bin/env bash
#MISE description="Manage custom dotfiles packages (add/remove configs not in default set)"
#MISE raw=true
set -eo pipefail

# ─── Helpers ───────────────────────────────────────────────────────────────────

TASK_NAME="setup:custom-dotfiles"
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../lib/helpers.sh"

# Read current device tag (default to "default" if not set)
if [[ -f "$DEVICE_TAG_FILE" ]]; then
    DEVICE_TAG="$(<"$DEVICE_TAG_FILE")"
else
    DEVICE_TAG="default"
fi

# Known non-package directories at repo root
NON_PKG_DIRS=(.git .github .claude scripts)

# ─── Utility functions ────────────────────────────────────────────────────────

# Compute the relative path from $HOME to a given path
# e.g., /home/user/.config/alacritty -> .config/alacritty
home_relative_path() {
    local abs_path
    abs_path="$(realpath "$1")"
    printf '%s' "${abs_path#"$HOME"/}"
}

# Infer a package name from a path
# ~/.config/alacritty -> alacritty
# ~/.tool-config -> tool-config
infer_package_name() {
    local name
    name="$(basename "$1")"
    # Strip leading dot (e.g., .something -> something)
    name="${name#.}"
    printf '%s' "$name"
}

# Check if a path is already a stow symlink pointing into the dotfiles repo
is_stow_symlink() {
    local path="$1"
    if [[ -L "$path" ]]; then
        local target
        target="$(readlink -f "$path")"
        [[ "$target" == "$DOTFILES_DIR"/* || "$target" == "$CUSTOM_DIR"/* ]] && return 0
    fi
    return 1
}

# ─── Directory management ────────────────────────────────────────────────────

ensure_custom_dir() {
    if [[ -d "$CUSTOM_DIR" ]]; then
        ok "Custom directory exists: $CUSTOM_DIR"
        return 0
    fi

    info "Custom packages directory not found: $CUSTOM_DIR"
    printf 'Create it now? (Y/n): '
    read -r confirm
    [[ "$confirm" =~ ^[Nn]$ ]] && return 1

    mkdir -p "$CUSTOM_DIR"

    printf 'Initialize as a git repository? (Y/n): '
    read -r init_git
    if [[ ! "$init_git" =~ ^[Nn]$ ]]; then
        git -C "$CUSTOM_DIR" init
        printf '*.bak\n*.bak.*\n' >"$CUSTOM_DIR/.gitignore"
        git -C "$CUSTOM_DIR" add .gitignore
        git -C "$CUSTOM_DIR" commit -m "init: custom dotfiles repo"
        ok "Initialized git repo in $CUSTOM_DIR"
    fi

    ok "Created custom directory: $CUSTOM_DIR"
}

# ─── Consistency check ────────────────────────────────────────────────────────

verify_custom_packages() {
    [[ -f "$CUSTOM_FILE" ]] || return 0
    read_custom_packages

    local dirty=false
    local -a remove_indices=()

    for i in "${!PKG_NAMES[@]}"; do
        local name="${PKG_NAMES[$i]}"
        local tag="${PKG_TAGS[$i]}"
        local tag_dir="$CUSTOM_DIR/$name/tag-$tag"
        if [[ ! -d "$tag_dir" ]]; then
            warn "Custom package '$name' (tag: $tag) — directory missing: $tag_dir"
            printf '  Remove from tracking file? (y/N): '
            read -r confirm
            if [[ "$confirm" =~ ^[Yy]$ ]]; then
                remove_indices+=("$i")
                dirty=true
            fi
        fi
    done

    if [[ "$dirty" == "true" ]]; then
        local -a new_names=() new_tags=() new_sources=() new_types=() new_recurse=()
        for i in "${!PKG_NAMES[@]}"; do
            if ! in_array "$i" "${remove_indices[@]}"; then
                new_names+=("${PKG_NAMES[$i]}")
                new_tags+=("${PKG_TAGS[$i]}")
                new_sources+=("${PKG_SOURCES[$i]}")
                new_types+=("${PKG_TYPES[$i]}")
                new_recurse+=("${PKG_RECURSE_DIRS[$i]}")
            fi
        done
        PKG_NAMES=("${new_names[@]}")
        PKG_TAGS=("${new_tags[@]}")
        PKG_SOURCES=("${new_sources[@]}")
        PKG_TYPES=("${new_types[@]}")
        PKG_RECURSE_DIRS=("${new_recurse[@]}")
        write_custom_packages
        if [[ -d "$CUSTOM_DIR/.git" ]]; then
            git -C "$CUSTOM_DIR" add .custom-packages
            git -C "$CUSTOM_DIR" commit -m "custom: clean up stale entries"
        fi
        ok "Cleaned up stale entries"
    fi
}

# ─── Add workflow ─────────────────────────────────────────────────────────────

add_custom_package() {
    printf 'Enter path to config file or directory (e.g., ~/.config/alacritty): '
    read -r source_path

    [[ -z "$source_path" ]] && return 1

    # Expand ~ to $HOME
    source_path="${source_path/#\~/$HOME}"

    # Validate: path exists
    if [[ ! -e "$source_path" ]]; then
        warn "Path does not exist: $source_path"
        return 1
    fi

    # Validate: not already a stow symlink
    if is_stow_symlink "$source_path"; then
        warn "Path is already a stow-managed symlink: $source_path"
        return 1
    fi

    # Infer and confirm package name
    local default_name
    default_name="$(infer_package_name "$source_path")"
    printf 'Package name [%s]: ' "$default_name"
    read -r pkg_name
    pkg_name="${pkg_name:-$default_name}"

    # Validate: check for conflict with default packages
    if in_array "$pkg_name" "${ALL_DEFAULT_PACKAGES[@]}"; then
        read_exclusions
        if in_array "$pkg_name" "${EXCLUDED[@]}"; then
            info "Default package '$pkg_name' is excluded — allowing custom override"
        else
            warn "Package '$pkg_name' conflicts with a non-excluded default package"
            printf '  Add '\''%s'\'' to .stow-exclude? (y/N): ' "$pkg_name"
            read -r confirm
            if [[ "$confirm" =~ ^[Yy]$ ]]; then
                EXCLUDED+=("$pkg_name")
                write_exclusions
                info "  Added '$pkg_name' to .stow-exclude"
            else
                return 1
            fi
        fi
    fi

    # Choose tag
    local pkg_tag="default"
    if [[ "$DEVICE_TAG" != "default" ]]; then
        printf 'Tag this config as? [d]efault / [m]achine tag (%s) / Enter for default: ' "$DEVICE_TAG"
        read -r tag_choice
        case "${tag_choice,,}" in
        m | machine) pkg_tag="$DEVICE_TAG" ;;
        d | default | "") pkg_tag="default" ;;
        *) warn "Unrecognized input, using default"; pkg_tag="default" ;;
        esac
    fi

    # Validate: (name, tag) not already a custom package
    for i in "${!PKG_NAMES[@]}"; do
        if [[ "${PKG_NAMES[$i]}" == "$pkg_name" && "${PKG_TAGS[$i]}" == "$pkg_tag" ]]; then
            warn "Package '$pkg_name' (tag: $pkg_tag) is already a custom package"
            return 1
        fi
    done

    # Validate: tag directory doesn't already exist
    if [[ -d "$CUSTOM_DIR/$pkg_name/tag-$pkg_tag" ]]; then
        warn "Directory '$pkg_name/tag-$pkg_tag' already exists in the custom packages directory"
        return 1
    fi

    local rel_path
    rel_path="$(home_relative_path "$source_path")"
    local pkg_type="full"
    local recurse_dirs_value=""

    if [[ -d "$source_path" ]]; then
        # Ask full vs partial
        printf 'Include entire directory, or select specific items? [f]ull / [p]artial: '
        read -r dir_mode

        case "${dir_mode,,}" in
        p | partial)
            pkg_type="partial"
            recurse_dirs_value="$rel_path"

            # List directory contents for selection
            local -a entries=()
            while IFS= read -r entry; do
                entries+=("$entry")
            done < <(ls -A1 "$source_path")

            if ((${#entries[@]} == 0)); then
                warn "Directory is empty"
                return 1
            fi

            info "Contents of $source_path:"
            for i in "${!entries[@]}"; do
                local marker=""
                if [[ -d "$source_path/${entries[$i]}" ]]; then
                    marker="/"
                fi
                printf '  %d) %s%s\n' "$((i + 1))" "${entries[$i]}" "$marker"
            done
            printf 'Enter numbers to include (space-separated): '
            read -r selections

            [[ -z "$selections" ]] && { warn "No items selected"; return 1; }

            # Create package directory with tagged stow layout
            local pkg_dir="$CUSTOM_DIR/$pkg_name/tag-$pkg_tag/$rel_path"
            mkdir -p "$pkg_dir"

            for sel in $selections; do
                if [[ "$sel" =~ ^[0-9]+$ ]] && ((sel >= 1 && sel <= ${#entries[@]})); then
                    local item="${entries[$((sel - 1))]}"
                    cp -a "$source_path/$item" "$pkg_dir/$item"
                    info "  Added: $item"
                else
                    warn "  Invalid selection: $sel"
                fi
            done
            ;;
        f | full | "")
            pkg_type="full"
            # Create package directory with tagged stow layout
            local pkg_dir="$CUSTOM_DIR/$pkg_name/tag-$pkg_tag/$rel_path"
            mkdir -p "$(dirname "$pkg_dir")"
            cp -a "$source_path" "$pkg_dir"
            info "  Copied full directory: $source_path"
            ;;
        *)
            warn "Unrecognized input, defaulting to full"
            pkg_type="full"
            local pkg_dir="$CUSTOM_DIR/$pkg_name/tag-$pkg_tag/$rel_path"
            mkdir -p "$(dirname "$pkg_dir")"
            cp -a "$source_path" "$pkg_dir"
            info "  Copied full directory: $source_path"
            ;;
        esac
    else
        # Single file
        local pkg_dir="$CUSTOM_DIR/$pkg_name/tag-$pkg_tag/$(dirname "$rel_path")"
        mkdir -p "$pkg_dir"
        cp -a "$source_path" "$pkg_dir/$(basename "$source_path")"
        info "  Copied file: $source_path"
    fi

    # Collapse tilde for display in tracking file
    local display_source="~/${rel_path}"

    # Update tracking arrays and write
    PKG_NAMES+=("$pkg_name")
    PKG_TAGS+=("$pkg_tag")
    PKG_SOURCES+=("$display_source")
    PKG_TYPES+=("$pkg_type")
    PKG_RECURSE_DIRS+=("$recurse_dirs_value")
    write_custom_packages

    # Auto-commit
    if [[ -d "$CUSTOM_DIR/.git" ]]; then
        git -C "$CUSTOM_DIR" add "$pkg_name" .custom-packages
        git -C "$CUSTOM_DIR" commit -m "custom: add $pkg_name (tag: $pkg_tag)"
    fi
    ok_changed "Added custom package: $pkg_name (tag: $pkg_tag)"
    return 0
}

# ─── Remove workflow ──────────────────────────────────────────────────────────

remove_custom_package() {
    read_custom_packages

    if ((${#PKG_NAMES[@]} == 0)); then
        warn "No custom packages to remove"
        return 1
    fi

    # Filter to only show entries matching current device tag or default
    local -a filtered_indices=()
    for i in "${!PKG_NAMES[@]}"; do
        if [[ "${PKG_TAGS[$i]}" == "$DEVICE_TAG" || "${PKG_TAGS[$i]}" == "default" ]]; then
            filtered_indices+=("$i")
        fi
    done

    if ((${#filtered_indices[@]} == 0)); then
        warn "No custom packages matching current device tag '$DEVICE_TAG'"
        return 1
    fi

    info "Custom packages (tag: $DEVICE_TAG):"
    local display_num=1
    for i in "${filtered_indices[@]}"; do
        local tag_display="${PKG_TAGS[$i]}"
        printf '  %d) %s:%s (%s, %s)\n' "$display_num" "${PKG_NAMES[$i]}" "$tag_display" "${PKG_SOURCES[$i]}" "${PKG_TYPES[$i]}"
        ((display_num++))
    done
    printf 'Enter numbers to remove (space-separated), or Enter to cancel: '
    read -r selections

    [[ -z "$selections" ]] && return 1

    # Map user selections back to original array indices
    local -a remove_indices=()
    for sel in $selections; do
        if [[ "$sel" =~ ^[0-9]+$ ]] && ((sel >= 1 && sel <= ${#filtered_indices[@]})); then
            remove_indices+=("${filtered_indices[$((sel - 1))]}")
        else
            warn "  Invalid selection: $sel"
        fi
    done

    local -a git_dirs=()
    for idx in "${remove_indices[@]}"; do
        local pkg="${PKG_NAMES[$idx]}"
        local tag="${PKG_TAGS[$idx]}"

        # Unstow the specific tagged variant
        local tag_dir="$CUSTOM_DIR/$pkg/tag-$tag"
        if [[ -d "$tag_dir" ]]; then
            info "  Unstowing $pkg (tag: $tag)..."
            stow -D -d "$CUSTOM_DIR/$pkg" -t "$HOME" "tag-$tag" 2>/dev/null || true

            # Restore backups scoped to this package's files
            while IFS= read -r -d '' rel_path; do
                [[ -z "$rel_path" ]] && continue
                local target="$HOME/$rel_path"
                local restore_from=""
                local i=1
                if [[ -e "$target.bak" ]]; then
                    restore_from="$target.bak"
                fi
                while [[ -e "$target.bak.$i" ]]; do
                    restore_from="$target.bak.$i"
                    ((i++))
                done
                if [[ -n "$restore_from" ]]; then
                    mv "$restore_from" "$target"
                    info "  Restored backup: $restore_from -> $target"
                fi
            done < <(find "$tag_dir" -mindepth 1 \( -type f -o -type l \) \
                -not -path '*/.git/*' -not -name '.git' \
                -printf '%P\0' 2>/dev/null)

            rm -rf "$tag_dir"
            info "  Removed tag directory: $pkg/tag-$tag"
        fi

        # If no tag-* dirs remain, remove the entire package directory
        if [[ -d "$CUSTOM_DIR/$pkg" ]]; then
            local remaining_tags
            remaining_tags=$(find "$CUSTOM_DIR/$pkg" -maxdepth 1 -type d -name 'tag-*' 2>/dev/null | wc -l)
            if ((remaining_tags == 0)); then
                rm -rf "$CUSTOM_DIR/$pkg"
                info "  Removed package directory: $pkg (no tagged variants remain)"
            fi
        fi

        git_dirs+=("$pkg")
    done

    # Rebuild arrays without removed entries
    local -a new_names=() new_tags=() new_sources=() new_types=() new_recurse=()
    for i in "${!PKG_NAMES[@]}"; do
        local keep=true
        for idx in "${remove_indices[@]}"; do
            if ((i == idx)); then
                keep=false
                break
            fi
        done
        if [[ "$keep" == true ]]; then
            new_names+=("${PKG_NAMES[$i]}")
            new_tags+=("${PKG_TAGS[$i]}")
            new_sources+=("${PKG_SOURCES[$i]}")
            new_types+=("${PKG_TYPES[$i]}")
            new_recurse+=("${PKG_RECURSE_DIRS[$i]}")
        fi
    done
    PKG_NAMES=("${new_names[@]}")
    PKG_TAGS=("${new_tags[@]}")
    PKG_SOURCES=("${new_sources[@]}")
    PKG_TYPES=("${new_types[@]}")
    PKG_RECURSE_DIRS=("${new_recurse[@]}")
    write_custom_packages

    # Auto-commit
    if [[ -d "$CUSTOM_DIR/.git" ]]; then
        cd "$CUSTOM_DIR"
        for pkg in "${git_dirs[@]}"; do
            git add -A "$pkg" 2>/dev/null || true
        done
        git add .custom-packages
        git commit -m "custom: remove ${git_dirs[*]}"
    fi
    ok_changed "Removed custom package(s): ${git_dirs[*]}"
    return 0
}

# ─── Main ─────────────────────────────────────────────────────────────────────

info "Phase 0: Custom dotfiles packages"

# Check if .custom-packages exists — if not and no intent to add, skip quickly
if [[ ! -f "$CUSTOM_FILE" ]]; then
    printf 'No custom packages configured. Add custom configs to dotfiles? (y/N): '
    read -r want_custom
    if [[ ! "$want_custom" =~ ^[Yy]$ ]]; then
        ok "Skipping custom packages"
        exit 0
    fi
fi

# Ensure custom directory exists
if ! ensure_custom_dir; then
    info "Cancelled."
    exit 0
fi

# Consistency check
verify_custom_packages

# Reload after potential cleanup
read_custom_packages

# ─── p10k auto-adoption ────────────────────────────────────────────────────
read_exclusions
if [[ -f "$HOME/.p10k.zsh" && ! -L "$HOME/.p10k.zsh" ]] \
    && in_array "p10k" "${EXCLUDED[@]}" \
    && ! in_array "p10k" "${PKG_NAMES[@]}"; then

    info "Detected ~/.p10k.zsh as a real file with p10k excluded"
    info "Auto-adding as a custom package..."

    if ensure_custom_dir; then
        pkg_tag="default"
        pkg_dir="$CUSTOM_DIR/p10k/tag-$pkg_tag"
        mkdir -p "$pkg_dir"
        cp "$HOME/.p10k.zsh" "$pkg_dir/.p10k.zsh"

        PKG_NAMES+=("p10k")
        PKG_TAGS+=("$pkg_tag")
        PKG_SOURCES+=("~/.p10k.zsh")
        PKG_TYPES+=("full")
        PKG_RECURSE_DIRS+=("")
        write_custom_packages

        if [[ -d "$CUSTOM_DIR/.git" ]]; then
            git -C "$CUSTOM_DIR" add "p10k" .custom-packages
            git -C "$CUSTOM_DIR" commit -m "custom: auto-add p10k (wizard output)"
        fi

        ok_changed "Added p10k as custom package (tag: $pkg_tag)"
    else
        warn "Cannot create custom dir — skipping p10k auto-add"
    fi
fi

# Interactive add/remove loop
while true; do
    if ((${#PKG_NAMES[@]} > 0)); then
        pkg_list=""
        for i in "${!PKG_NAMES[@]}"; do
            [[ -n "$pkg_list" ]] && pkg_list+=", "
            pkg_list+="${PKG_NAMES[$i]}:${PKG_TAGS[$i]}"
        done
        info "Current custom packages: $pkg_list"
    else
        info "No custom packages configured"
    fi

    printf '[a]dd / [r]emove / Enter to finish: '
    read -r action

    case "${action,,}" in
    a | add)
        add_custom_package || true
        read_custom_packages  # refresh arrays
        ;;
    r | remove)
        remove_custom_package || true
        read_custom_packages  # refresh arrays
        ;;
    "")
        break
        ;;
    *)
        warn "Unrecognized input '$action'"
        ;;
    esac
done

if ((${#PKG_NAMES[@]} > 0)); then
    ok "Custom packages: ${PKG_NAMES[*]}"
else
    ok "No custom packages"
fi
