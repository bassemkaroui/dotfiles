#!/usr/bin/env bash
#MISE description="Deploy dotfiles via GNU Stow (clones repo if missing, resolves device tag)"
#MISE raw=true
set -eo pipefail

# ─── Helpers ───────────────────────────────────────────────────────────────────

TASK_NAME="setup:dotfiles"
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../lib/helpers.sh"

# Find next available .bak suffix: .bak, .bak.1, .bak.2, ...
next_backup_path() {
    local path="$1"
    local backup="$path.bak"
    local i=1
    while [[ -e "$backup" ]]; do
        backup="$path.bak.$i"
        ((i++))
    done
    printf '%s' "$backup"
}

# Directories that should always be recursed into (never backed up wholesale).
# These contain unmanaged files (GPG keys, generated completions, auth tokens)
# that must be left in place.
# RECURSE_DIRS=(.gnupg .config/gh .claude .claude/plugins)
DOTFILES_DIR="$HOME/.dotfiles"
CUSTOM_DIR="${DOTFILES_CUSTOM_DIR:-$HOME/.dotfiles-custom}"

RECURSE_DIRS=(.gnupg .config/gh .claude .ssh)

# Custom packages arrays — populated after Phase 3 (needs DEVICE_TAG)
CUSTOM_PACKAGES=()
CUSTOM_PKG_TAGS=()
CUSTOM_FILE="$CUSTOM_DIR/.custom-packages"

is_recurse_dir() {
    local path="$1"
    for d in "${RECURSE_DIRS[@]}"; do
        [[ "$path" == "$d" ]] && return 0
    done
    return 1
}

declare -gA SHARED_DIRS

compute_shared_dirs() {
    local -a all_pkg_dirs=("$@")
    local -A dir_counts

    for pkg_dir in "${all_pkg_dirs[@]}"; do
        [[ -d "$pkg_dir" ]] || continue
        while IFS= read -r -d '' rel_dir; do
            [[ -z "$rel_dir" ]] && continue
            dir_counts["$rel_dir"]=$((${dir_counts["$rel_dir"]:-0} + 1))
        done < <(find "$pkg_dir" -mindepth 1 -type d \
            -not -path '*/.git/*' -not -name '.git' \
            -printf '%P\0' 2>/dev/null)
    done

    for dir_path in "${!dir_counts[@]}"; do
        if ((dir_counts["$dir_path"] >= 2)); then
            SHARED_DIRS["$dir_path"]=1
        fi
    done
}

backup_conflicts() {
    local pkg_dir="$1"
    local target="$2"
    local rel_prefix="${3:-}"

    for entry in "$pkg_dir"/.* "$pkg_dir"/*; do
        [[ -e "$entry" ]] || continue
        local name
        name="$(basename "$entry")"
        [[ "$name" == "." || "$name" == ".." ]] && continue

        local target_path="$target/$name"
        [[ -e "$target_path" ]] || continue # no conflict
        [[ -L "$target_path" ]] && continue # already a symlink, skip

        if [[ -f "$target_path" ]]; then
            local bak_path
            bak_path="$(next_backup_path "$target_path")"
            mv "$target_path" "$bak_path"
            info "  Backed up: $target_path -> $bak_path"
        elif [[ -d "$entry" && -d "$target_path" ]]; then
            local rel_path
            if [[ -n "$rel_prefix" ]]; then
                rel_path="$rel_prefix/$name"
            else
                rel_path="$name"
            fi

            if [[ -n "${SHARED_DIRS["$rel_path"]+_}" ]] || is_recurse_dir "$rel_path"; then
                # Shared directory (used by multiple packages) — descend
                backup_conflicts "$entry" "$target_path" "$rel_path"
            else
                # Package-owned directory — back up entirely
                local bak_path
                bak_path="$(next_backup_path "$target_path")"
                mv "$target_path" "$bak_path"
                info "  Backed up: $target_path -> $bak_path"
            fi
        fi
    done
}

# Resolve which tag-* subdirectory to use for a package.
# Sets STOW_TAG_DIR to the resolved subdirectory name (e.g. "tag-laptop"),
# or empty if no matching tag found (package should be skipped).
resolve_tag_dir() {
    local pkg_dir="$1" tag="$2"
    STOW_TAG_DIR=""

    if [[ -d "$pkg_dir/tag-$tag" ]]; then
        STOW_TAG_DIR="tag-$tag"
    elif [[ -d "$pkg_dir/tag-default" ]]; then
        STOW_TAG_DIR="tag-default"
    fi
}

DOTFILES_REPO="git@github.com:your-username/.dotfiles.git"

# ─── Phase 1: Clone dotfiles repo if missing ─────────────────────────────────

info "Phase 1: Dotfiles repository"
if [[ -d "$DOTFILES_DIR/.git" ]]; then
    ok "Dotfiles repo already exists at $DOTFILES_DIR"
else
    info "Dotfiles repo not found at $DOTFILES_DIR"
    info ""
    info "This will clone from: $DOTFILES_REPO"
    info "Make sure your SSH key is set up for GitHub."
    info "  - Check: ssh -T git@github.com"
    info "  - Setup: https://docs.github.com/en/authentication/connecting-to-github-with-ssh"
    info ""
    printf 'Is your git/SSH auth ready? (y/N): '
    read -r AUTH_READY
    if [[ ! "$AUTH_READY" =~ ^[Yy]$ ]]; then
        info "Please set up git auth and re-run this task."
        exit 0
    fi

    info "Cloning dotfiles..."
    git clone --recursive "$DOTFILES_REPO" "$DOTFILES_DIR"

    # Ensure tmux submodule is on master
    if [[ -d "$DOTFILES_DIR/tmux/tag-default/.tmux" ]]; then
        info "Checking out tmux submodule to master..."
        cd "$DOTFILES_DIR/tmux/tag-default/.tmux"
        git checkout master
    fi

    # Ensure nvim submodule is on custom_config
    if [[ -d "$DOTFILES_DIR/nvim/tag-default/.config/nvim" ]]; then
        info "Checking out nvim submodule to custom_config..."
        cd "$DOTFILES_DIR/nvim/tag-default/.config/nvim"
        git checkout custom_config
    fi

    cd "$DOTFILES_DIR"
    git config submodule.recurse true
    ok_changed "Dotfiles repo cloned and configured"
fi

# ─── Phase 2: Verify stow is available ───────────────────────────────────────

info "Phase 2: Verify stow"
command -v stow &>/dev/null || fail "stow not found. Run: mise run install:stow"
ok "stow available: $(command -v stow)"

# ─── Phase 3: Resolve device tag ─────────────────────────────────────────────

DEVICE_TAG_FILE="$DOTFILES_DIR/.device-tag"

info "Phase 3: Resolve device tag"

# Read old tag before any changes (for detecting tag switches)
OLD_DEVICE_TAG=""
if [[ -f "$DEVICE_TAG_FILE" ]]; then
    OLD_DEVICE_TAG="$(<"$DEVICE_TAG_FILE")"
fi

if [[ -n "${DOTFILES_TAG:-}" ]]; then
    DEVICE_TAG="$DOTFILES_TAG"
    info "Using DOTFILES_TAG from environment: $DEVICE_TAG"
elif [[ -f "$DEVICE_TAG_FILE" ]]; then
    DEVICE_TAG="$(<"$DEVICE_TAG_FILE")"
    info "Using persisted device tag: $DEVICE_TAG"
else
    printf 'No device tag set. Tag for this machine [default]: '
    read -r DEVICE_TAG
    DEVICE_TAG="${DEVICE_TAG:-default}"
fi

# Validate tag
if [[ ! "$DEVICE_TAG" =~ ^[a-zA-Z0-9_-]+$ ]]; then
    fail "Invalid device tag '$DEVICE_TAG'. Must contain only letters, numbers, hyphens, and underscores."
fi

ok "Device tag: $DEVICE_TAG"

# Persist tag for future runs
printf '%s' "$DEVICE_TAG" >"$DEVICE_TAG_FILE"

# ─── Load custom packages (needs DEVICE_TAG for tag resolution) ──────────────

if [[ -f "$CUSTOM_FILE" ]]; then
    local_name="" local_tag=""
    # Parallel arrays for all entries (before tag filtering)
    ALL_CUSTOM_NAMES=() ALL_CUSTOM_TAGS=()
    while IFS= read -r line; do
        line="${line%%#*}"
        [[ -z "${line// /}" ]] && continue
        if [[ "$line" =~ ^\[([^:]+)(:(.+))?\]$ ]]; then
            [[ -n "$local_name" ]] && ALL_CUSTOM_NAMES+=("$local_name") && ALL_CUSTOM_TAGS+=("$local_tag")
            local_name="${BASH_REMATCH[1]}"
            local_tag="${BASH_REMATCH[3]:-default}"
        elif [[ "$line" =~ ^recurse_dirs=(.+)$ ]]; then
            IFS=',' read -ra rdirs <<<"${BASH_REMATCH[1]}"
            for rd in "${rdirs[@]}"; do
                rd="${rd// /}"
                [[ -n "$rd" ]] && RECURSE_DIRS+=("$rd")
            done
        fi
    done <"$CUSTOM_FILE"
    [[ -n "$local_name" ]] && ALL_CUSTOM_NAMES+=("$local_name") && ALL_CUSTOM_TAGS+=("$local_tag")

    # Tag resolution: for each unique package name, pick exact $DEVICE_TAG match,
    # fall back to "default", or skip
    declare -A _seen_cpkg
    for i in "${!ALL_CUSTOM_NAMES[@]}"; do
        local_name="${ALL_CUSTOM_NAMES[$i]}"
        local_tag="${ALL_CUSTOM_TAGS[$i]}"
        # Skip if we already resolved this package
        [[ -n "${_seen_cpkg[$local_name]+x}" ]] && continue

        resolved_tag=""
        fallback_tag=""
        for j in "${!ALL_CUSTOM_NAMES[@]}"; do
            if [[ "${ALL_CUSTOM_NAMES[$j]}" == "$local_name" ]]; then
                if [[ "${ALL_CUSTOM_TAGS[$j]}" == "$DEVICE_TAG" ]]; then
                    resolved_tag="$DEVICE_TAG"
                    break
                elif [[ "${ALL_CUSTOM_TAGS[$j]}" == "default" ]]; then
                    fallback_tag="default"
                fi
            fi
        done

        resolved_tag="${resolved_tag:-$fallback_tag}"
        if [[ -n "$resolved_tag" ]] && [[ -d "$CUSTOM_DIR/$local_name/tag-$resolved_tag" ]]; then
            CUSTOM_PACKAGES+=("$local_name")
            CUSTOM_PKG_TAGS+=("$resolved_tag")
        fi
        _seen_cpkg[$local_name]=1
    done
    unset _seen_cpkg
fi

# ─── Phase 3.5: Manage stow exclusions ──────────────────────────────────────

STOW_EXCLUDE_FILE="$DOTFILES_DIR/.stow-exclude"
ALL_PACKAGES=(bash fzf git gnome_themes gpg zsh tmux bat yazi mise nvim gh gh-dash claude ghostty ssh p10k)

info "Phase 3.5: Stow exclusions"

# Create .stow-exclude with header if missing
if [[ ! -f "$STOW_EXCLUDE_FILE" ]]; then
    cat >"$STOW_EXCLUDE_FILE" <<'HEADER'
# Stow package exclusion list (per-machine, gitignored)
# Add one package name per line to skip it during setup:dotfiles
# Available packages: bash fzf git gnome_themes gpg zsh tmux bat yazi mise nvim gh gh-dash claude ghostty ssh p10k
HEADER
    info "Created $STOW_EXCLUDE_FILE — edit to skip packages on this machine"
fi

# Read current exclusions from file (strip comments and blank lines)
read_exclusions() {
    EXCLUDED=()
    while IFS= read -r line; do
        line="${line%%#*}" # strip inline comments
        line="${line// /}" # strip spaces
        [[ -z "$line" ]] && continue
        EXCLUDED+=("$line")
    done <"$STOW_EXCLUDE_FILE"
}

# Write exclusions back to file (preserves header comments)
write_exclusions() {
    # Keep only comment/blank lines from original, then append exclusions
    local tmpfile
    tmpfile="$(mktemp)"
    grep -E '^\s*(#|$)' "$STOW_EXCLUDE_FILE" >"$tmpfile" || true
    for pkg in "${EXCLUDED[@]}"; do
        printf '%s\n' "$pkg" >>"$tmpfile"
    done
    mv "$tmpfile" "$STOW_EXCLUDE_FILE"
}

# Check if a value is in an array
in_array() {
    local needle="$1"
    shift
    for item in "$@"; do
        [[ "$item" == "$needle" ]] && return 0
    done
    return 1
}

# Unstow a package and restore backups if any exist
unstow_package() {
    local pkg="$1"
    local base_dir="${2:-$DOTFILES_DIR}"

    # Unstow all tag-* variants (user may have switched tags)
    for tag_dir in "$base_dir/$pkg"/tag-*/; do
        [[ -d "$tag_dir" ]] || continue
        local tag_name
        tag_name="$(basename "$tag_dir")"
        stow -D -d "$base_dir/$pkg" -t "$HOME" "$tag_name" 2>/dev/null || true
        info "  Unstowed: $pkg/$tag_name"
    done

    # Restore backups: find .bak files that belong to this package
    local -a search_dirs=()
    for tag_dir in "$base_dir/$pkg"/tag-*/; do
        [[ -d "$tag_dir" ]] && search_dirs+=("$tag_dir")
    done

    for pkg_dir in "${search_dirs[@]}"; do
        [[ -d "$pkg_dir" ]] || continue
        while IFS= read -r -d '' rel_path; do
            [[ -z "$rel_path" ]] && continue
            local target="$HOME/$rel_path"
            # Find the highest numbered backup
            local restore_from=""
            local i=1
            if [[ -e "$target.bak" ]]; then
                restore_from="$target.bak"
            fi
            while [[ -e "$target.bak.$i" ]]; do
                restore_from="$target.bak.$i"
                ((i++))
            done
            if [[ -n "$restore_from" ]]; then
                mv "$restore_from" "$target"
                info "  Restored: $restore_from -> $target"
            fi
        done < <(find "$pkg_dir" -mindepth 1 \( -type f -o -type l \) \
            -not -path '*/.git/*' -not -name '.git' \
            -printf '%P\0' 2>/dev/null)
    done
}

# Interactive exclusion management loop
while true; do
    read_exclusions

    if ((${#EXCLUDED[@]} > 0)); then
        info "Currently excluded: ${EXCLUDED[*]}"
    else
        info "No packages currently excluded"
    fi

    printf 'Modify exclusions? [a]dd / [r]emove / Enter to keep: '
    read -r MODIFY_CHOICE

    case "${MODIFY_CHOICE,,}" in
    a | add)
        # Build list of available (non-excluded) packages
        AVAILABLE=()
        for pkg in "${ALL_PACKAGES[@]}"; do
            in_array "$pkg" "${EXCLUDED[@]}" && continue
            in_array "$pkg" "${CUSTOM_PACKAGES[@]}" && continue
            AVAILABLE+=("$pkg")
        done
        if ((${#AVAILABLE[@]} == 0)); then
            warn "All packages are already excluded"
            continue
        fi
        info "Available packages:"
        for i in "${!AVAILABLE[@]}"; do
            printf '  %d) %s\n' "$((i + 1))" "${AVAILABLE[$i]}"
        done
        printf 'Enter numbers to exclude (space-separated), or Enter to cancel: '
        read -r ADD_CHOICES
        [[ -z "$ADD_CHOICES" ]] && continue
        for choice in $ADD_CHOICES; do
            if [[ "$choice" =~ ^[0-9]+$ ]] && ((choice >= 1 && choice <= ${#AVAILABLE[@]})); then
                local_pkg="${AVAILABLE[$((choice - 1))]}"
                EXCLUDED+=("$local_pkg")
                info "  Added: $local_pkg"
            else
                warn "  Invalid selection: $choice"
            fi
        done
        write_exclusions
        ;;
    r | remove)
        if ((${#EXCLUDED[@]} == 0)); then
            warn "No packages to remove from exclusions"
            continue
        fi
        info "Currently excluded packages:"
        for i in "${!EXCLUDED[@]}"; do
            printf '  %d) %s\n' "$((i + 1))" "${EXCLUDED[$i]}"
        done
        printf 'Enter numbers to un-exclude (space-separated), or Enter to cancel: '
        read -r REMOVE_CHOICES
        [[ -z "$REMOVE_CHOICES" ]] && continue
        TO_REMOVE=()
        for choice in $REMOVE_CHOICES; do
            if [[ "$choice" =~ ^[0-9]+$ ]] && ((choice >= 1 && choice <= ${#EXCLUDED[@]})); then
                TO_REMOVE+=("${EXCLUDED[$((choice - 1))]}")
                info "  Removed: ${EXCLUDED[$((choice - 1))]}"
            else
                warn "  Invalid selection: $choice"
            fi
        done
        # Rebuild EXCLUDED without removed items
        NEW_EXCLUDED=()
        for pkg in "${EXCLUDED[@]}"; do
            in_array "$pkg" "${TO_REMOVE[@]}" || NEW_EXCLUDED+=("$pkg")
        done
        EXCLUDED=("${NEW_EXCLUDED[@]}")
        write_exclusions
        ;;
    "")
        break
        ;;
    *)
        warn "Unrecognized input '$MODIFY_CHOICE'"
        ;;
    esac
done

# Warn and remove custom packages from exclusions
read_exclusions
EXCLUSIONS_CLEANED=false
for cpkg in "${CUSTOM_PACKAGES[@]}"; do
    if in_array "$cpkg" "${EXCLUDED[@]}"; then
        warn "Custom package '$cpkg' found in .stow-exclude — ignoring exclusion"
        NEW_EXCLUDED=()
        for pkg in "${EXCLUDED[@]}"; do
            [[ "$pkg" != "$cpkg" ]] && NEW_EXCLUDED+=("$pkg")
        done
        EXCLUDED=("${NEW_EXCLUDED[@]}")
        EXCLUSIONS_CLEANED=true
    fi
done
if [[ "$EXCLUSIONS_CLEANED" == "true" ]]; then
    write_exclusions
    warn "Updated .stow-exclude to remove conflicting custom package entries"
fi

# Unstow any newly-excluded packages that have symlinks in $HOME
read_exclusions
for pkg in "${EXCLUDED[@]}"; do
    unstow_package "$pkg"
done

if ((${#EXCLUDED[@]} > 0)); then
    ok "Exclusions applied: ${EXCLUDED[*]}"
else
    ok "No exclusions"
fi

# ─── Precompute shared directories ───────────────────────────────────────────

# Filter packages based on exclusions
PACKAGES=()
for pkg in "${ALL_PACKAGES[@]}"; do
    in_array "$pkg" "${EXCLUDED[@]}" || PACKAGES+=("$pkg")
done

ALL_PKG_DIRS=()
for pkg in "${PACKAGES[@]}"; do
    resolve_tag_dir "$DOTFILES_DIR/$pkg" "$DEVICE_TAG"
    if [[ -n "$STOW_TAG_DIR" ]]; then
        ALL_PKG_DIRS+=("$DOTFILES_DIR/$pkg/$STOW_TAG_DIR")
    fi
done
for i in "${!CUSTOM_PACKAGES[@]}"; do
    cpkg="${CUSTOM_PACKAGES[$i]}"
    ctag="${CUSTOM_PKG_TAGS[$i]}"
    if [[ -d "$CUSTOM_DIR/$cpkg/tag-$ctag" ]]; then
        ALL_PKG_DIRS+=("$CUSTOM_DIR/$cpkg/tag-$ctag")
    fi
done

compute_shared_dirs "${ALL_PKG_DIRS[@]}"

# ─── Phase 4: Deploy packages ───────────────────────────────────────────────

info "Phase 4: Deploy stow packages (tag: $DEVICE_TAG)"

STOWED_PACKAGES=()

for pkg in "${PACKAGES[@]}"; do
    if [[ ! -d "$DOTFILES_DIR/$pkg" ]]; then
        warn "Package directory '$pkg' not found, skipping"
        continue
    fi

    resolve_tag_dir "$DOTFILES_DIR/$pkg" "$DEVICE_TAG"

    if [[ -n "$STOW_TAG_DIR" ]]; then
        backup_conflicts "$DOTFILES_DIR/$pkg/$STOW_TAG_DIR" "$HOME"
        stow -d "$DOTFILES_DIR/$pkg" -R -t "$HOME" "$STOW_TAG_DIR" 2>&1 | { grep -v '^BUG in find_stowed_path' || true; } | while read -r line; do
            info "  $line"
        done
        STOWED_PACKAGES+=("$pkg")
        ok_changed "$pkg config deployed ($STOW_TAG_DIR)"
    else
        info "  Skipping $pkg (no tag-$DEVICE_TAG or tag-default variant)"
    fi
done
ok_changed "Packages deployed: ${STOWED_PACKAGES[*]}"

# Deploy custom packages (from sibling directory, tag-aware)
if ((${#CUSTOM_PACKAGES[@]} > 0)); then
    info "Deploying custom packages (from $CUSTOM_DIR)"
    for i in "${!CUSTOM_PACKAGES[@]}"; do
        local cpkg="${CUSTOM_PACKAGES[$i]}"
        local ctag="${CUSTOM_PKG_TAGS[$i]}"
        if [[ ! -d "$CUSTOM_DIR/$cpkg/tag-$ctag" ]]; then
            warn "Custom package '$cpkg' tag-$ctag directory missing in $CUSTOM_DIR, skipping"
            continue
        fi
        backup_conflicts "$CUSTOM_DIR/$cpkg/tag-$ctag" "$HOME"
        stow -d "$CUSTOM_DIR/$cpkg" -R -t "$HOME" "tag-$ctag" 2>&1 | { grep -v '^BUG in find_stowed_path' || true; } | while read -r line; do
            info "  $line"
        done
        ok_changed "$cpkg custom config deployed (tag-$ctag)"
    done
    ok_changed "Custom packages deployed: ${CUSTOM_PACKAGES[*]}"
fi

# ─── Phase 5: Ensure tmux submodule is on master ─────────────────────────────

info "Phase 5: Tmux submodule"
if [[ -e "$DOTFILES_DIR/tmux/tag-default/.tmux/.git" ]]; then
    cd "$DOTFILES_DIR/tmux/tag-default/.tmux"
    CURRENT_BRANCH="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
    if [[ "$CURRENT_BRANCH" != "master" ]]; then
        git checkout master
        ok_changed "tmux submodule checked out to master"
    else
        ok "tmux submodule already on master"
    fi
else
    warn "tmux submodule not found at tmux/tag-default/.tmux"
fi

# ─── Phase 6: Ensure nvim submodule is on custom_config ──────────────────────

info "Phase 6: Neovim submodule"
if [[ -e "$DOTFILES_DIR/nvim/tag-default/.config/nvim/.git" ]]; then
    cd "$DOTFILES_DIR/nvim/tag-default/.config/nvim"
    CURRENT_BRANCH="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
    if [[ "$CURRENT_BRANCH" != "custom_config" ]]; then
        git checkout custom_config
        ok_changed "nvim submodule checked out to custom_config"
    else
        ok "nvim submodule already on custom_config"
    fi
else
    warn "nvim submodule not found at nvim/tag-default/.config/nvim"
fi

# ─── Phase 7: Verify ─────────────────────────────────────────────────────────

info "Phase 7: Verification"
VERIFY_FILES=("$HOME/.zshrc" "$HOME/.gitconfig" "$HOME/.config/nvim/init.lua" "$HOME/.claude/settings.json")
# Add device-tag-specific files if they were stowed
if in_array "ssh" "${STOWED_PACKAGES[@]}"; then
    VERIFY_FILES+=("$HOME/.ssh/config")
fi
if in_array "p10k" "${STOWED_PACKAGES[@]}"; then
    VERIFY_FILES+=("$HOME/.p10k.zsh")
fi
for f in "${VERIFY_FILES[@]}"; do
    if [[ -L "$f" || -f "$f" ]]; then
        ok "  $f"
    else
        warn "  $f not found"
    fi
done

printf '\n'
info "============================================"
info "  dotfiles deployment complete!"
info "  Device tag: $DEVICE_TAG"
info "============================================"
printf '\n'
