#!/usr/bin/env bash
#MISE description="Manage stow package exclusions (.stow-exclude)"
#MISE raw=true
set -eo pipefail

# ─── Helpers ───────────────────────────────────────────────────────────────────

TASK_NAME="setup:exclude"
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../lib/helpers.sh"

# Read device tag
if [[ -f "$DEVICE_TAG_FILE" ]]; then
    DEVICE_TAG="$(<"$DEVICE_TAG_FILE")"
else
    DEVICE_TAG="default"
fi

# ─── Load custom package names (read-only, for UI filtering) ──────────────────

CUSTOM_PACKAGES=()
if [[ -f "$CUSTOM_FILE" ]]; then
    local_name=""
    ALL_CUSTOM_NAMES=() ALL_CUSTOM_TAGS=()
    while IFS= read -r line; do
        line="${line%%#*}"
        [[ -z "${line// /}" ]] && continue
        if [[ "$line" =~ ^\[([^:]+)(:(.+))?\]$ ]]; then
            [[ -n "$local_name" ]] && ALL_CUSTOM_NAMES+=("$local_name") && ALL_CUSTOM_TAGS+=("$local_tag")
            local_name="${BASH_REMATCH[1]}"
            local_tag="${BASH_REMATCH[3]:-default}"
        fi
    done <"$CUSTOM_FILE"
    [[ -n "$local_name" ]] && ALL_CUSTOM_NAMES+=("$local_name") && ALL_CUSTOM_TAGS+=("$local_tag")

    # Resolve custom package names for current device tag
    declare -A _seen_cpkg
    for i in "${!ALL_CUSTOM_NAMES[@]}"; do
        local_name="${ALL_CUSTOM_NAMES[$i]}"
        [[ -n "${_seen_cpkg[$local_name]+x}" ]] && continue

        resolved_tag="" fallback_tag=""
        for j in "${!ALL_CUSTOM_NAMES[@]}"; do
            if [[ "${ALL_CUSTOM_NAMES[$j]}" == "$local_name" ]]; then
                if [[ "${ALL_CUSTOM_TAGS[$j]}" == "$DEVICE_TAG" ]]; then
                    resolved_tag="$DEVICE_TAG"; break
                elif [[ "${ALL_CUSTOM_TAGS[$j]}" == "default" ]]; then
                    fallback_tag="default"
                fi
            fi
        done

        resolved_tag="${resolved_tag:-$fallback_tag}"
        if [[ -n "$resolved_tag" ]] && [[ -d "$CUSTOM_DIR/$local_name/tag-$resolved_tag" ]]; then
            CUSTOM_PACKAGES+=("$local_name")
        fi
        _seen_cpkg[$local_name]=1
    done
    unset _seen_cpkg
fi

# ─── Manage stow exclusions ──────────────────────────────────────────────────

info "Stow exclusions"

# Create .stow-exclude with header if missing
if [[ ! -f "$STOW_EXCLUDE_FILE" ]]; then
    cat >"$STOW_EXCLUDE_FILE" <<'HEADER'
# Stow package exclusion list (per-machine, gitignored)
# Add one package name per line to skip it during setup:dotfiles
# Available packages: bash fzf gnome_themes gpg zsh tmux bat yazi mise nvim gh gh-dash claude ghostty ssh p10k
HEADER
    info "Created $STOW_EXCLUDE_FILE — edit to skip packages on this machine"
fi

# ─── p10k symlink-clobber detection ─────────────────────────────────────────
if [[ -f "$HOME/.p10k.zsh" && ! -L "$HOME/.p10k.zsh" ]] && ! in_array "p10k" "${EXCLUDED[@]}"; then
    warn "~/.p10k.zsh is a real file (not a stow symlink)"
    info "This usually happens after running 'p10k configure'."
    info "If p10k is not excluded, setup:dotfiles will back up this file and restore the old config."
    printf 'Exclude p10k from stow? (Y/n): '
    read -r confirm
    if [[ ! "$confirm" =~ ^[Nn]$ ]]; then
        EXCLUDED+=("p10k")
        write_exclusions
        unstow_package "p10k"
        ok_changed "Excluded p10k and unstowed existing symlinks"
    fi
fi

# Interactive exclusion management loop
while true; do
    read_exclusions

    if ((${#EXCLUDED[@]} > 0)); then
        info "Currently excluded: ${EXCLUDED[*]}"
    else
        info "No packages currently excluded"
    fi

    printf 'Modify exclusions? [a]dd / [r]emove / Enter to keep: '
    read -r MODIFY_CHOICE

    case "${MODIFY_CHOICE,,}" in
    a | add)
        # Build list of available (non-excluded) packages, hiding custom overrides
        AVAILABLE=()
        for pkg in "${ALL_DEFAULT_PACKAGES[@]}"; do
            in_array "$pkg" "${EXCLUDED[@]}" && continue
            in_array "$pkg" "${CUSTOM_PACKAGES[@]}" && continue
            AVAILABLE+=("$pkg")
        done
        if ((${#AVAILABLE[@]} == 0)); then
            warn "All packages are already excluded"
            continue
        fi
        info "Available packages:"
        for i in "${!AVAILABLE[@]}"; do
            printf '  %d) %s\n' "$((i + 1))" "${AVAILABLE[$i]}"
        done
        printf 'Enter numbers to exclude (space-separated), or Enter to cancel: '
        read -r ADD_CHOICES
        [[ -z "$ADD_CHOICES" ]] && continue
        for choice in $ADD_CHOICES; do
            if [[ "$choice" =~ ^[0-9]+$ ]] && ((choice >= 1 && choice <= ${#AVAILABLE[@]})); then
                local_pkg="${AVAILABLE[$((choice - 1))]}"
                EXCLUDED+=("$local_pkg")
                info "  Added: $local_pkg"
            else
                warn "  Invalid selection: $choice"
            fi
        done
        write_exclusions
        ;;
    r | remove)
        if ((${#EXCLUDED[@]} == 0)); then
            warn "No packages to remove from exclusions"
            continue
        fi
        info "Currently excluded packages:"
        for i in "${!EXCLUDED[@]}"; do
            printf '  %d) %s\n' "$((i + 1))" "${EXCLUDED[$i]}"
        done
        printf 'Enter numbers to un-exclude (space-separated), or Enter to cancel: '
        read -r REMOVE_CHOICES
        [[ -z "$REMOVE_CHOICES" ]] && continue
        TO_REMOVE=()
        for choice in $REMOVE_CHOICES; do
            if [[ "$choice" =~ ^[0-9]+$ ]] && ((choice >= 1 && choice <= ${#EXCLUDED[@]})); then
                TO_REMOVE+=("${EXCLUDED[$((choice - 1))]}")
                info "  Removed: ${EXCLUDED[$((choice - 1))]}"
            else
                warn "  Invalid selection: $choice"
            fi
        done
        # Rebuild EXCLUDED without removed items
        NEW_EXCLUDED=()
        for pkg in "${EXCLUDED[@]}"; do
            in_array "$pkg" "${TO_REMOVE[@]}" || NEW_EXCLUDED+=("$pkg")
        done
        EXCLUDED=("${NEW_EXCLUDED[@]}")
        write_exclusions
        ;;
    "")
        break
        ;;
    *)
        warn "Unrecognized input '$MODIFY_CHOICE'"
        ;;
    esac
done

# Unstow any newly-excluded packages that have symlinks in $HOME
read_exclusions
for pkg in "${EXCLUDED[@]}"; do
    unstow_package "$pkg"
done

if ((${#EXCLUDED[@]} > 0)); then
    ok "Exclusions applied: ${EXCLUDED[*]}"
else
    ok "No exclusions"
fi
