#!/usr/bin/env bash
#MISE description="Run powerlevel10k interactive configuration wizard"
#MISE raw=true
set -eo pipefail

# ─── Helpers ───────────────────────────────────────────────────────────────────

TASK_NAME="setup:p10k"
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../lib/helpers.sh"

# Resolve symlink target if present, otherwise return path as-is
resolve_file() {
    if [[ -L "$1" ]]; then
        readlink -f "$1"
    else
        echo "$1"
    fi
}

# Prepare ~/.p10k.zsh for modification.
# - Symlink -> main repo: break it (don't modify the default template)
# - Symlink -> custom repo: leave it (writes go through to custom repo)
# - Symlink -> elsewhere: break it with a warning
# - Broken symlink: remove it
# - Real file: leave as-is
# Sets P10K_CUSTOM_TARGET to the resolved path if symlink points to custom repo.
P10K_CUSTOM_TARGET=""

prepare_p10k_file() {
    local p10k="$HOME/.p10k.zsh"
    P10K_CUSTOM_TARGET=""

    if [[ -L "$p10k" ]]; then
        local target
        target="$(readlink -f "$p10k" 2>/dev/null || true)"

        if [[ -z "$target" || ! -e "$target" ]]; then
            rm -f "$p10k"
            warn "Removed broken symlink: ~/.p10k.zsh"
            return 1
        fi

        if [[ "$target" == "$CUSTOM_DIR"/* ]]; then
            P10K_CUSTOM_TARGET="$target"
            info "~/.p10k.zsh points to custom repo"
        elif [[ "$target" == "$DOTFILES_DIR"/* ]]; then
            cp --remove-destination "$target" "$p10k"
            info "Replaced default-repo symlink with a real file"
        else
            cp --remove-destination "$target" "$p10k"
            warn "Replaced symlink (target: $target) with a real file"
        fi
    elif [[ ! -f "$p10k" ]]; then
        warn "~/.p10k.zsh does not exist — run p10k configure to create it"
        return 1
    fi
    return 0
}

# After modifying p10k, sync changes back to custom repo and auto-commit
sync_custom_p10k() {
    [[ -n "$P10K_CUSTOM_TARGET" ]] || return 0

    local p10k="$HOME/.p10k.zsh"

    # If the wizard destroyed the symlink, copy the new file back and re-stow
    if [[ ! -L "$p10k" && -f "$p10k" ]]; then
        cp "$p10k" "$P10K_CUSTOM_TARGET"
        # Re-create the symlink by stowing
        local pkg_dir="$CUSTOM_DIR/p10k"
        local tag_dir
        tag_dir="$(basename "$(dirname "$P10K_CUSTOM_TARGET")")"
        stow -d "$pkg_dir" -t "$HOME" -R "$tag_dir" 2>/dev/null \
            && info "Re-stowed custom p10k symlink" \
            || warn "Could not re-stow p10k — symlink may need manual fix"
    fi

    # Auto-commit if custom dir is a git repo
    if [[ -d "$CUSTOM_DIR/.git" ]]; then
        local changed
        changed="$(git -C "$CUSTOM_DIR" diff --name-only -- 'p10k/' 2>/dev/null || true)"
        if [[ -n "$changed" ]]; then
            git -C "$CUSTOM_DIR" add p10k/
            git -C "$CUSTOM_DIR" commit -m "update p10k config"
            ok_changed "Auto-committed p10k changes to custom repo"
        fi
    fi
}

if [[ ! -d "${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}/themes/powerlevel10k" ]]; then
    echo "Error: powerlevel10k not installed. Run 'mise run setup:zsh' first."
    exit 1
fi

# ─── Ensure ZSH_THEME is set to p10k ─────────────────────────────────────────

ZSHRC="$(resolve_file "$HOME/.zshrc")"
if [[ -f "$ZSHRC" ]]; then
    if grep -q '^ZSH_THEME="powerlevel10k/powerlevel10k"' "$ZSHRC" 2>/dev/null; then
        ok "ZSH_THEME already set to powerlevel10k"
    else
        if grep -q '^ZSH_THEME=' "$ZSHRC"; then
            sed -i 's/^ZSH_THEME=.*/ZSH_THEME="powerlevel10k\/powerlevel10k"/' "$ZSHRC"
            ok_changed "Updated ZSH_THEME to powerlevel10k in .zshrc"
        else
            # Insert before 'source $ZSH/oh-my-zsh.sh' if present, otherwise append
            if grep -q 'source.*oh-my-zsh.sh' "$ZSHRC"; then
                sed -i '/source.*oh-my-zsh.sh/i ZSH_THEME="powerlevel10k/powerlevel10k"' "$ZSHRC"
            else
                printf '\nZSH_THEME="powerlevel10k/powerlevel10k"\n' >> "$ZSHRC"
            fi
            ok_changed "Added ZSH_THEME=powerlevel10k to .zshrc"
        fi
    fi
else
    warn "No .zshrc found — p10k configure may not work"
fi

printf 'Would you like to configure powerlevel10k now? (y/N): '
read -r CONFIGURE_P10K
if [[ "$CONFIGURE_P10K" =~ ^[Yy]$ ]]; then
    if prepare_p10k_file; then
        zsh -i -c 'p10k configure'
        sync_custom_p10k
    fi
else
    echo "Skipped. You can run 'mise run setup:p10k-configure' later."
fi

# ─── OS icon prompt (interactive) ────────────────────────────────────────────

info "OS icon in p10k"
printf 'Would you like to change the OS icon in p10k? (y/N): '
read -r CHANGE_ICON
if [[ "$CHANGE_ICON" =~ ^[Yy]$ ]]; then
    printf 'Browse icons at https://www.nerdfonts.com/cheat-sheet\n'
    printf 'Paste your desired icon: '
    read -r NEW_ICON
    if [[ -n "$NEW_ICON" ]]; then
        if ! prepare_p10k_file; then
            warn "Cannot modify p10k config"
        else
            # Write to the resolved target if custom, otherwise ~/.p10k.zsh
            P10K_FILE="${P10K_CUSTOM_TARGET:-$HOME/.p10k.zsh}"
            if [[ -f "$P10K_FILE" ]]; then
                # Use awk to safely handle special characters in the icon
                awk -v icon="$NEW_ICON" '
                    /POWERLEVEL9K_OS_ICON_CONTENT_EXPANSION/ { next }
                    /POWERLEVEL9K_OS_ICON_BACKGROUND/ {
                        print
                        print "  typeset -g POWERLEVEL9K_OS_ICON_CONTENT_EXPANSION=\047" icon "\047"
                        next
                    }
                    { print }
                ' "$P10K_FILE" > "${P10K_FILE}.tmp" && mv -f "${P10K_FILE}.tmp" "$P10K_FILE"
                ok_changed "OS icon updated in .p10k.zsh"
                sync_custom_p10k
            else
                warn ".p10k.zsh not found — run p10k configure first"
            fi
        fi
    fi
else
    ok "OS icon unchanged"
fi
