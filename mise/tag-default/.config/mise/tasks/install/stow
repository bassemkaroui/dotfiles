#!/usr/bin/env bash
#MISE description="Install GNU Stow (via package manager or from source)"
#MISE depends=["install:build-deps"]
#MISE raw=true
set -eo pipefail

# ─── Helpers ───────────────────────────────────────────────────────────────────

TASK_NAME="install:stow"
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../lib/helpers.sh"

# ─── Phase 1: Check if stow is already installed ─────────────────────────────

info "Phase 1: Check if stow is already installed"
if command -v stow &>/dev/null; then
    ok "stow already installed: $(command -v stow) ($(stow --version 2>&1 | head -1))"
    exit 0
fi

# ─── Phase 2: Try package manager with sudo ──────────────────────────────────

info "Phase 2: Try installing via package manager"
INSTALLED=false

if command -v sudo &>/dev/null; then
    if command -v nala &>/dev/null; then
        info "Trying: sudo nala install stow -y"
        if sudo nala install stow -y; then
            INSTALLED=true
        fi
    fi

    if [[ "$INSTALLED" == false ]] && command -v apt-get &>/dev/null; then
        info "Trying: sudo apt-get install -y stow"
        if sudo apt-get install -y stow; then
            INSTALLED=true
        fi
    fi

    if [[ "$INSTALLED" == false ]] && command -v dnf &>/dev/null; then
        info "Trying: sudo dnf install -y stow"
        if sudo dnf install -y stow; then
            INSTALLED=true
        fi
    fi

    if [[ "$INSTALLED" == false ]] && command -v pacman &>/dev/null; then
        info "Trying: sudo pacman -S --noconfirm stow"
        if sudo pacman -S --noconfirm stow; then
            INSTALLED=true
        fi
    fi
else
    info "sudo not available, skipping package manager install"
fi

if [[ "$INSTALLED" == true ]] && command -v stow &>/dev/null; then
    ok_changed "stow installed via package manager: $(command -v stow)"
    exit 0
fi

# ─── Phase 3: Build from source ──────────────────────────────────────────────

info "Phase 3: Building stow from source into ~/.local/"

command -v perl &>/dev/null || fail "Cannot build stow: 'perl' not found. Install Perl first."
command -v make &>/dev/null || fail "Cannot build stow: 'make' not found. Install build tools first."

STOW_VERSION="2.4.1"
STOW_TARBALL="stow-${STOW_VERSION}.tar.gz"
STOW_URL="https://ftp.gnu.org/gnu/stow/${STOW_TARBALL}"

TMPDIR_STOW="$(mktemp -d)"
trap 'rm -rf "$TMPDIR_STOW"' EXIT

info "Downloading stow ${STOW_VERSION}..."
curl -fSL -o "$TMPDIR_STOW/$STOW_TARBALL" "$STOW_URL"

cd "$TMPDIR_STOW"
tar xzf "$STOW_TARBALL"
cd "stow-${STOW_VERSION}"

info "Configuring with --prefix=$HOME/.local ..."
./configure --prefix="$HOME/.local" --quiet

info "Installing..."
make install --quiet

cd "$HOME"

# Ensure ~/.local/bin is in PATH for current session
if [[ ":$PATH:" != *":$HOME/.local/bin:"* ]]; then
    export PATH="$HOME/.local/bin:$PATH"
fi

# ─── Phase 4: Verify ─────────────────────────────────────────────────────────

info "Phase 4: Verify installation"
if command -v stow &>/dev/null; then
    ok_changed "stow built from source and installed to ~/.local/bin/stow"
else
    fail "stow installation failed — binary not found in PATH"
fi

printf '\n'
info "============================================"
info "  stow installation complete!"
info "============================================"
printf '\n'
