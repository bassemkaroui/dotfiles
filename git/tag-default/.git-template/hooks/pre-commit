#!/usr/bin/env bash

# Define color codes
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

copy_to_clipboard() {
    if command -v xclip > /dev/null; then
        echo -n "$1" | xclip -selection clipboard
    elif command -v xsel > /dev/null; then
        echo -n "$1" | xsel --clipboard --input
    elif command -v pbcopy > /dev/null; then
        echo -n "$1" | pbcopy
    else
        echo "No clipboard utility found. Please install xclip, xsel, or pbcopy." 1>&2
        return 1
    fi
    return 0
}

if [ -f .pre-commit-config.yaml ]; then
    echo -e "${RED}Error${NC} pre-commit configuration detected, but 'pre-commit install -f' was never run" 1>&2

    # Copy command to clipboard
    if copy_to_clipboard 'pre-commit install -f'; then
        echo -e "${YELLOW}Info${NC} The command 'pre-commit install -f' was copied to your clipboard. Just paste it to run."
    else
        echo -e "${YELLOW}Info${NC} Please install a clipboard utility (xclip, xsel, or pbcopy) to copy the command automatically."
    fi
    exit 1
fi
